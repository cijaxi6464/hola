<?xml version="1.0" encoding="utf-8"?>
<tt
  xmlns="http://www.w3.org/ns/ttml"
  xmlns:ttm="http://www.w3.org/ns/ttml#metadata"
  xmlns:tts="http://www.w3.org/ns/ttml#styling"
  xmlns:ttp="http://www.w3.org/ns/ttml#parameter"
  ttp:cellResolution="384 288"
  xml:lang="">
  <head>
    <layout>
      <region xml:id="Default"
        tts:origin="3% 0%"
        tts:extent="97% 97%"
        tts:displayAlign="after"
        tts:textAlign="center"
        tts:fontSize="16c"
        tts:fontFamily="Arial"
        tts:overflow="visible" />
    </layout>
  </head>
  <body>
    <div>
      <p
        begin="00:00:01.625"
        end="00:00:07.541"><span region="Default">UNTUK MENGENANG DENGAN PENUH KASIH<br/>13 OCTOBER 1942 - 15 OCTOBER 2008</span></p>
      <p
        begin="00:00:34.333"
        end="00:00:35.583"><span region="Default">Siapa ini?</span></p>
      <p
        begin="00:00:36.208"
        end="00:00:37.916"><span region="Default">Namanya Suroso.</span></p>
      <p
        begin="00:00:38.000"
        end="00:00:39.625"><span region="Default">Lurah Karang Setan.</span></p>
      <p
        begin="00:00:40.625"
        end="00:00:42.625"><span region="Default">Mau diapakan orang ini?</span></p>
      <p
        begin="00:00:43.541"
        end="00:00:45.583"><span region="Default">Aku mau dia cepat mati.</span></p>
      <p
        begin="00:00:48.708"
        end="00:00:50.875"><span region="Default">Kenapa harus mati?</span></p>
      <p
        begin="00:00:53.500"
        end="00:00:55.166"><span region="Default">Supaya aku</span></p>
      <p
        begin="00:00:55.250"
        end="00:00:57.916"><span region="Default">bisa menggantikan dia<br/>menjadi lurah Karang Setan.</span></p>
      <p
        begin="00:00:59.166"
        end="00:01:01.416"><span region="Default">Kamu siap menanggung dosa?</span></p>
      <p
        begin="00:01:04.166"
        end="00:01:05.666"><span region="Default">Kalau tidak siap,</span></p>
      <p
        begin="00:01:05.750"
        end="00:01:07.916"><span region="Default">aku tidak akan ke sini menemuimu.</span></p>
      <p
        begin="00:01:28.083"
        end="00:01:29.125"><span region="Default">Pardi.</span></p>
      <p
        begin="00:01:32.041"
        end="00:01:33.958"><span region="Default">Potong separuh buat bayar utang.</span></p>
      <p
        begin="00:01:36.750"
        end="00:01:37.625"><span region="Default">Daliman.</span></p>
      <p
        begin="00:01:37.708"
        end="00:01:40.208"><span region="Default">Buat apa kamu ikut antre?</span></p>
      <p
        begin="00:01:40.291"
        end="00:01:43.125"><span region="Default">Upahmu sudah habis kepotong utang!</span></p>
      <p
        begin="00:01:43.791"
        end="00:01:46.625"><span region="Default">Tolong, Pak Banteng.<br/>Cicilannya separuh dulu.</span></p>
      <p
        begin="00:01:47.250"
        end="00:01:48.375"><span region="Default">Saya ada perlu.</span></p>
      <p
        begin="00:01:50.625"
        end="00:01:51.833"><span region="Default">Terima kasih.</span></p>
      <p
        begin="00:02:05.708"
        end="00:02:06.791"><span region="Default">Ampun.</span></p>
      <p
        begin="00:02:06.875"
        end="00:02:08.875"><span region="Default">Makan nih bensin.</span></p>
      <p
        begin="00:02:09.833"
        end="00:02:11.916"><span region="Default">- Siram dia.<br/>- Tolong!</span></p>
      <p
        begin="00:02:16.041"
        end="00:02:18.458"><span region="Default">- Ampun, Pak.<br/>- Terus.</span></p>
      <p
        begin="00:02:35.416"
        end="00:02:37.541"><span region="Default">Jangan bohong kamu.</span></p>
      <p
        begin="00:02:38.500"
        end="00:02:40.291"><span region="Default">Saya berani sumpah</span></p>
      <p
        begin="00:02:40.375"
        end="00:02:43.458"><span region="Default">kalau saya sudah<br/>tidak punya apa-apa lagi buat bayar utang.</span></p>
      <p
        begin="00:02:48.166"
        end="00:02:49.208"><span region="Default">Juragan.</span></p>
      <p
        begin="00:02:49.291"
        end="00:02:51.333"><span region="Default">Saya mohon, Juragan.</span></p>
      <p
        begin="00:02:52.333"
        end="00:02:55.375"><span region="Default">Saya mau menerima permintaan Pak Kawi.</span></p>
      <p
        begin="00:02:55.458"
        end="00:02:58.541"><span region="Default">Biar anak perempuan saya bekerja di sini</span></p>
      <p
        begin="00:02:58.625"
        end="00:03:00.041"><span region="Default">untuk membayar utang saya.</span></p>
      <p
        begin="00:03:05.083"
        end="00:03:06.500"><span region="Default">Iya.</span></p>
      <p
        begin="00:03:06.583"
        end="00:03:08.791"><span region="Default">Saya ke sini, kau ke sana.</span></p>
      <p
        begin="00:03:23.666"
        end="00:03:25.041"><span region="Default">Saya Lawu.</span></p>
      <p
        begin="00:03:35.375"
        end="00:03:37.375"><span region="Default">- Sini.<br/>- Pak…</span></p>
      <p
        begin="00:03:37.458"
        end="00:03:39.250"><span region="Default">Udah, udah.</span></p>
      <p
        begin="00:03:49.416"
        end="00:03:51.166"><span region="Default">Pak. Jangan, Pak.</span></p>
      <p
        begin="00:03:51.958"
        end="00:03:53.625"><span region="Default">Pak. Jangan, Pak.</span></p>
      <p
        begin="00:03:54.291"
        end="00:03:56.791"><span region="Default">Tolong! Tolong, Pak!</span></p>
      <p
        begin="00:03:58.041"
        end="00:03:59.583"><span region="Default">Pak, tolong!</span></p>
      <p
        begin="00:03:59.666"
        end="00:04:01.666"><span region="Default">- Nak?<br/>- Pak!</span></p>
      <p
        begin="00:04:01.750"
        end="00:04:04.583"><span region="Default">- Nak? Nak!<br/>- Pak. Jangan, Pak.</span></p>
      <p
        begin="00:04:04.666"
        end="00:04:06.083"><span region="Default">Nak!</span></p>
      <p
        begin="00:04:07.458"
        end="00:04:08.625"><span region="Default">Nak!</span></p>
      <p
        begin="00:04:28.125"
        end="00:04:29.291"><span region="Default">Mogok?</span></p>
      <p
        begin="00:04:33.583"
        end="00:04:35.166"><span region="Default">Iya, Mas.</span></p>
      <p
        begin="00:04:35.250"
        end="00:04:36.583"><span region="Default">Boleh saya bantu?</span></p>
      <p
        begin="00:04:38.416"
        end="00:04:39.708"><span region="Default">Boleh, Mas.</span></p>
      <p
        begin="00:04:52.083"
        end="00:04:53.458"><span region="Default">Jarang dipakai, ya?</span></p>
      <p
        begin="00:04:54.625"
        end="00:04:55.916"><span region="Default">Jarang sekali.</span></p>
      <p
        begin="00:04:57.041"
        end="00:04:59.583"><span region="Default">Biasanya Bapak yang suka pakai motornya.</span></p>
      <p
        begin="00:05:05.291"
        end="00:05:06.791"><span region="Default">Alhamdulillah.</span></p>
      <p
        begin="00:05:08.291"
        end="00:05:10.291"><span region="Default">- Terima kasih, Mas.<br/>- Sama-sama.</span></p>
      <p
        begin="00:05:11.958"
        end="00:05:13.375"><span region="Default">Maaf sudah merepotkan.</span></p>
      <p
        begin="00:05:14.041"
        end="00:05:15.166"><span region="Default">Tidak merepotkan.</span></p>
      <p
        begin="00:05:15.250"
        end="00:05:17.291"><span region="Default">Kalau harus bongkar mesin baru repot.</span></p>
      <p
        begin="00:05:18.833"
        end="00:05:20.250"><span region="Default">Uh, ini kantor</span></p>
      <p
        begin="00:05:20.333"
        end="00:05:23.541"><span region="Default">buka atau tutup, kok sepi?</span></p>
      <p
        begin="00:05:24.208"
        end="00:05:25.583"><span region="Default">Buka, kok.</span></p>
      <p
        begin="00:05:25.666"
        end="00:05:27.583"><span region="Default">Cuma Pak Lurahnya tidak ada.</span></p>
      <p
        begin="00:05:27.666"
        end="00:05:29.458"><span region="Default">Dua minggu yang lalu baru meninggal dunia.</span></p>
      <p
        begin="00:05:29.541"
        end="00:05:31.208"><span region="Default">Innalillahi.</span></p>
      <p
        begin="00:05:31.958"
        end="00:05:33.083"><span region="Default">Makasih.</span></p>
      <p
        begin="00:05:34.083"
        end="00:05:35.375"><span region="Default">Assalamualaikum.</span></p>
      <p
        begin="00:05:35.458"
        end="00:05:37.083"><span region="Default">Waalaikumsalam.</span></p>
      <p
        begin="00:05:53.208"
        end="00:05:56.208"><span region="Default">Saya mau mencari orang<br/>yang dulu pernah tinggal di sini.</span></p>
      <p
        begin="00:05:56.833"
        end="00:05:59.916"><span region="Default">- Siapa, Mas?<br/>- Namanya Kasman Wironegoro.</span></p>
      <p
        begin="00:06:00.000"
        end="00:06:01.250"><span region="Default">Kasman?</span></p>
      <p
        begin="00:06:02.625"
        end="00:06:04.041"><span region="Default">Gun, tau?</span></p>
      <p
        begin="00:06:04.125"
        end="00:06:06.416"><span region="Default">Ya, kejadiannya sudah cukup lama.<br/>Waktu itu saya masih kecil.</span></p>
      <p
        begin="00:06:06.500"
        end="00:06:09.375"><span region="Default">Gini aja. Kita bantu cari<br/>di kabupaten, Mas.</span></p>
      <p
        begin="00:06:09.458"
        end="00:06:11.250"><span region="Default">Nanti datang lagi aja.</span></p>
      <p
        begin="00:06:11.750"
        end="00:06:14.125"><span region="Default">Maaf. Nama siapa?</span></p>
      <p
        begin="00:06:14.208"
        end="00:06:15.166"><span region="Default">Saya Pramuja.</span></p>
      <p
        begin="00:06:16.250"
        end="00:06:17.375"><span region="Default">Tolong diisi.</span></p>
      <p
        begin="00:06:27.125"
        end="00:06:28.458"><span region="Default">Maaf sudah merepotkan.</span></p>
      <p
        begin="00:06:29.125"
        end="00:06:30.458"><span region="Default">Tidak merepotkan.</span></p>
      <p
        begin="00:06:30.541"
        end="00:06:32.500"><span region="Default">Kalau harus bongkar mesin baru repot.</span></p>
      <p
        begin="00:06:41.500"
        end="00:06:44.125"><span region="Default">- Suzzanna?<br/>- Iya?</span></p>
      <p
        begin="00:06:46.375"
        end="00:06:47.708"><span region="Default">- Iya?<br/>- Dari siapa ini?</span></p>
      <p
        begin="00:06:49.500"
        end="00:06:50.916"><span region="Default">Dari Juragan Bisman?</span></p>
      <p
        begin="00:06:51.708"
        end="00:06:52.708"><span region="Default">Bu?</span></p>
      <p
        begin="00:06:53.291"
        end="00:06:54.333"><span region="Default">Lo…</span></p>
      <p
        begin="00:06:55.000"
        end="00:06:56.083"><span region="Default">Bu!</span></p>
      <p
        begin="00:06:57.125"
        end="00:06:59.166"><span region="Default">Kenapa diterima?</span></p>
      <p
        begin="00:07:00.541"
        end="00:07:05.416"><span region="Default">Lama-lama engga enak, Pak,<br/>kalau kita menolak pemberian Bisman.</span></p>
      <p
        begin="00:07:06.000"
        end="00:07:08.083"><span region="Default">Memang itu maunya.</span></p>
      <p
        begin="00:07:08.791"
        end="00:07:12.250"><span region="Default">Nunggu kita engga enak, sungkan.</span></p>
      <p
        begin="00:07:12.333"
        end="00:07:14.458"><span region="Default">Lama-lama, kita menerima lamaran dia.</span></p>
      <p
        begin="00:07:14.541"
        end="00:07:19.500"><span region="Default">Apa Bapak engga kasian sama<br/>anak perempuan kita, jadi perawan tua?</span></p>
      <p
        begin="00:07:19.583"
        end="00:07:23.458"><span region="Default">Bapak juga pengen<br/>Suzzanna itu cepat dapat suami, Bu.</span></p>
      <p
        begin="00:07:23.541"
        end="00:07:26.541"><span region="Default">Tapi bukan dengan lelaki<br/>yang sudah punya istri.</span></p>
      <p
        begin="00:07:26.625"
        end="00:07:28.708"><span region="Default">Apalagi yang namanya Bisman itu.</span></p>
      <p
        begin="00:07:28.791"
        end="00:07:30.083"><span region="Default">Aduh, Pak.</span></p>
      <p
        begin="00:07:30.166"
        end="00:07:33.541"><span region="Default">Suzzanna tidak akan sengsara.</span></p>
      <p
        begin="00:07:33.625"
        end="00:07:35.750"><span region="Default">Biarpun menjadi istri kedua.</span></p>
      <p
        begin="00:07:35.833"
        end="00:07:39.875"><span region="Default">Karena Bisman<br/>hartanya engga habis tujuh turunan.</span></p>
      <p
        begin="00:07:39.958"
        end="00:07:42.375"><span region="Default">Astaghfirullahaladzim, Bu.</span></p>
      <p
        begin="00:07:42.458"
        end="00:07:44.958"><span region="Default">Apa Ibu engga mikir,<br/>harta itu dia dapat dari mana?</span></p>
      <p
        begin="00:07:45.791"
        end="00:07:47.458"><span region="Default">Dengan cara apa?</span></p>
      <p
        begin="00:07:47.541"
        end="00:07:50.708"><span region="Default">Ya kita engga usah<br/>ngurusin kehidupan orang lain.</span></p>
      <p
        begin="00:07:51.291"
        end="00:07:54.958"><span region="Default">Yang penting,<br/>kita engga jahat, anak kita selamat.</span></p>
      <p
        begin="00:07:55.458"
        end="00:07:58.083"><span region="Default">Jadi begitu pendapat kamu?</span></p>
      <p
        begin="00:07:58.166"
        end="00:08:02.541"><span region="Default">Nduk, kamu mau?<br/>Menerima lamaran si Bisman itu?</span></p>
      <p
        begin="00:08:05.541"
        end="00:08:06.708"><span region="Default">Engga, Pak.</span></p>
      <p
        begin="00:08:06.791"
        end="00:08:08.083"><span region="Default">Lo, kenapa?</span></p>
      <p
        begin="00:08:08.958"
        end="00:08:10.833"><span region="Default">Ibu kamu bilang</span></p>
      <p
        begin="00:08:10.916"
        end="00:08:13.916"><span region="Default">harta si Bisman itu engga bakal habis lo,<br/>sampai tujuh turunan.</span></p>
      <p
        begin="00:08:14.583"
        end="00:08:17.500"><span region="Default">Aku bukannya tidak mau<br/>cepat-cepat menikah, Bu.</span></p>
      <p
        begin="00:08:18.500"
        end="00:08:20.750"><span region="Default">Tapi aku mau cari suami<br/>yang baik-baik saja.</span></p>
      <p
        begin="00:08:20.833"
        end="00:08:22.833"><span region="Default">Nah, betul itu.</span></p>
      <p
        begin="00:08:22.916"
        end="00:08:27.375"><span region="Default">Yang baik-baik itu kapan ketemunya?</span></p>
      <p
        begin="00:08:27.458"
        end="00:08:29.750"><span region="Default">Sebentar lagi pasti ketemu.</span></p>
      <p
        begin="00:08:31.083"
        end="00:08:34.666"><span region="Default">Aku bisa merasakan<br/>kalau jodohku sudah dekat.</span></p>
      <p
        begin="00:08:35.541"
        end="00:08:37.208"><span region="Default">Sok tahu kamu.</span></p>
      <p
        begin="00:08:45.125"
        end="00:08:46.458"><span region="Default">Ada apa ini?</span></p>
      <p
        begin="00:08:47.041"
        end="00:08:49.208"><span region="Default">Keadaan makin gawat, Pak Guru.</span></p>
      <p
        begin="00:08:51.583"
        end="00:08:52.958"><span region="Default">Masuk, masuk.</span></p>
      <p
        begin="00:09:01.250"
        end="00:09:02.208"><span region="Default">Maaf.</span></p>
      <p
        begin="00:09:02.708"
        end="00:09:04.333"><span region="Default">Saya ajak teman-teman ke sini,</span></p>
      <p
        begin="00:09:04.416"
        end="00:09:07.625"><span region="Default">berharap Bapak bisa cari jalan keluarnya.</span></p>
      <p
        begin="00:09:11.666"
        end="00:09:14.791"><span region="Default">Sebetulnya kalian 'kan tahu<br/>saya ini bukan siapa-siapa.</span></p>
      <p
        begin="00:09:15.916"
        end="00:09:17.583"><span region="Default">Saya cuma guru.</span></p>
      <p
        begin="00:09:17.666"
        end="00:09:21.500"><span region="Default">Tapi kalau menurut saya,<br/>Pak Satrio lebih dari sekadar guru.</span></p>
      <p
        begin="00:09:23.000"
        end="00:09:26.500"><span region="Default">Karena hanya Pak Satrio<br/>yang berani melawan anak buah Bisman.</span></p>
      <p
        begin="00:09:27.583"
        end="00:09:30.666"><span region="Default">Kalau waktu itu Pak Satrio tidak muncul,</span></p>
      <p
        begin="00:09:30.750"
        end="00:09:31.875"><span region="Default">mungkin saya sudah mati.</span></p>
      <p
        begin="00:09:37.375"
        end="00:09:40.375"><span region="Default">Pak Guru. Mau cari mati?</span></p>
      <p
        begin="00:09:40.458"
        end="00:09:42.500"><span region="Default">Kalian yang cari mati</span></p>
      <p
        begin="00:09:42.583"
        end="00:09:45.000"><span region="Default">Kalau masih nekat<br/>mengganggu pedagang di sini.</span></p>
      <p
        begin="00:09:45.666"
        end="00:09:47.958"><span region="Default">Bangsat ini orang.</span></p>
      <p
        begin="00:09:49.083"
        end="00:09:50.083"><span region="Default">Lihat.</span></p>
      <p
        begin="00:09:51.208"
        end="00:09:53.916"><span region="Default">Lihat semua. Mereka cuma berempat.</span></p>
      <p
        begin="00:09:54.958"
        end="00:09:57.041"><span region="Default">Tidak ada alasan untuk takut melawan.</span></p>
      <p
        begin="00:10:14.000"
        end="00:10:17.750"><span region="Default">Siapa pun bisa melakukan<br/>tindakan seperti yang saya lakukan</span></p>
      <p
        begin="00:10:18.333"
        end="00:10:21.458"><span region="Default">kalau menghadapi situasi seperti itu.</span></p>
      <p
        begin="00:10:21.541"
        end="00:10:24.000"><span region="Default">Tapi banyak juga yang malah lari, Pak.</span></p>
      <p
        begin="00:10:24.083"
        end="00:10:25.666"><span region="Default">Pak Guru Satrio,</span></p>
      <p
        begin="00:10:25.750"
        end="00:10:28.000"><span region="Default">sekarang bukan saatnya berendah hati.</span></p>
      <p
        begin="00:10:28.083"
        end="00:10:31.291"><span region="Default">Para warga di sini<br/>ingin Bapak memimpin perlawanan</span></p>
      <p
        begin="00:10:31.375"
        end="00:10:33.625"><span region="Default">terhadap Juragan Bisman.</span></p>
      <p
        begin="00:10:33.708"
        end="00:10:35.166"><span region="Default">Bukan dengan kekerasan,</span></p>
      <p
        begin="00:10:36.083"
        end="00:10:39.625"><span region="Default">tetapi lewat cara-cara<br/>yang tidak melanggar aturan.</span></p>
      <p
        begin="00:10:39.708"
        end="00:10:41.000"><span region="Default">Maksudnya?</span></p>
      <p
        begin="00:10:41.083"
        end="00:10:45.333"><span region="Default">Bapak harus mau mencalonkan diri<br/>pada pemilihan lurah bulan depan,</span></p>
      <p
        begin="00:10:45.416"
        end="00:10:47.958"><span region="Default">menggantikan almarhum Lurah Suroso.</span></p>
      <p
        begin="00:10:48.875"
        end="00:10:50.208"><span region="Default">Sebab kalau tidak,</span></p>
      <p
        begin="00:10:50.291"
        end="00:10:53.000"><span region="Default">Juragan Bisman akan maju sendirian<br/>sebagai calon tunggal.</span></p>
      <p
        begin="00:10:54.041"
        end="00:10:55.791"><span region="Default">Karena memang itu yang dia mau.</span></p>
      <p
        begin="00:11:07.250"
        end="00:11:11.083"><span region="Default">Pokoknya, Bapak tidak boleh<br/>berlagak mau jadi pahlawan, Pak.</span></p>
      <p
        begin="00:11:11.666"
        end="00:11:13.500"><span region="Default">Memang tidak.</span></p>
      <p
        begin="00:11:14.375"
        end="00:11:17.333"><span region="Default">Sekarang ini siapa pun<br/>harus mau jadi pahlawan.</span></p>
      <p
        begin="00:11:20.083"
        end="00:11:23.625"><span region="Default">Kelakuan Bisman dan anak buahnya<br/>sudah betul-betul biadab.</span></p>
      <p
        begin="00:11:23.708"
        end="00:11:26.791"><span region="Default">Dan tidak bisa dibiarkan<br/>oleh siapa pun. Termasuk Bapak.</span></p>
      <p
        begin="00:11:26.875"
        end="00:11:30.750"><span region="Default">Tapi orang-orang berharap Bapak<br/>yang maju untuk memimpin perlawanan.</span></p>
      <p
        begin="00:11:31.791"
        end="00:11:33.291"><span region="Default">Itu sedang Bapak pikirkan.</span></p>
      <p
        begin="00:11:34.791"
        end="00:11:37.750"><span region="Default">Pak, tidak usah ikut campur<br/>urusan orang lain, Pak.</span></p>
      <p
        begin="00:11:38.875"
        end="00:11:41.958"><span region="Default">Kalau perlu, kita saja<br/>yang pindah dari kampung ini, ya?</span></p>
      <p
        begin="00:11:42.041"
        end="00:11:43.833"><span region="Default">Nak.</span></p>
      <p
        begin="00:11:43.916"
        end="00:11:47.958"><span region="Default">Melawan kezaliman itu wajib hukumnya.</span></p>
      <p
        begin="00:11:48.041"
        end="00:11:51.583"><span region="Default">Coba, bagaimana kalau hal itu<br/>terjadi pada keluarga kita?</span></p>
      <p
        begin="00:11:51.666"
        end="00:11:53.375"><span region="Default">Apa kamu tidak akan minta bantuan?</span></p>
      <p
        begin="00:11:54.125"
        end="00:11:56.541"><span region="Default">Tapi harus Bapak yang maju untuk memimpin?</span></p>
      <p
        begin="00:11:56.625"
        end="00:11:59.416"><span region="Default">Siapa pun yang nanti jadi pemimpin,</span></p>
      <p
        begin="00:11:59.500"
        end="00:12:03.083"><span region="Default">semua harus siap menerima kenyataan<br/>bahwa setiap perubahan itu</span></p>
      <p
        begin="00:12:03.166"
        end="00:12:05.583"><span region="Default">akan menuntut pengorbanan.</span></p>
      <p
        begin="00:12:06.375"
        end="00:12:07.416"><span region="Default">Paham?</span></p>
      <p
        begin="00:12:09.000"
        end="00:12:10.833"><span region="Default">Betul, Pak.</span></p>
      <p
        begin="00:12:10.916"
        end="00:12:14.750"><span region="Default">Tapi jangan sampai Bapak<br/>menzalimi keluarga sendiri.</span></p>
      <p
        begin="00:12:14.833"
        end="00:12:15.958"><span region="Default">Ya engga lah.</span></p>
      <p
        begin="00:12:16.625"
        end="00:12:19.250"><span region="Default">Secara langsung memang engga lah.</span></p>
      <p
        begin="00:12:19.875"
        end="00:12:22.625"><span region="Default">Tapi akibat perbuatan Bapak, Bisman marah.</span></p>
      <p
        begin="00:12:22.708"
        end="00:12:26.250"><span region="Default">Dan membuat keluarga kita sengsara.<br/>Apa bedanya?</span></p>
      <p
        begin="00:12:26.333"
        end="00:12:28.000"><span region="Default">Alah.</span></p>
      <p
        begin="00:12:33.666"
        end="00:12:38.000"><span region="Default">Kalian yakin Satrio berani<br/>memimpin orang-orang buat melawan saya?</span></p>
      <p
        begin="00:12:38.083"
        end="00:12:42.625"><span region="Default">Yang saya dengar, pembicaraan mereka<br/>mengarah ke sana, Juragan.</span></p>
      <p
        begin="00:12:42.708"
        end="00:12:45.375"><span region="Default">Apa hebatnya? Memang dia jagoan?</span></p>
      <p
        begin="00:12:45.458"
        end="00:12:47.541"><span region="Default">Mungkin karena dia<br/>punya nyali buat melawan.</span></p>
      <p
        begin="00:12:48.291"
        end="00:12:49.291"><span region="Default">Melawan siapa?</span></p>
      <p
        begin="00:12:49.375"
        end="00:12:52.416"><span region="Default">- Saya sama anak-anak.<br/>- Dia bisa mengalahkan kalian?</span></p>
      <p
        begin="00:12:53.083"
        end="00:12:56.458"><span region="Default">Waktu itu engga jadi kelahi,<br/>tapi dia punya wibawa.</span></p>
      <p
        begin="00:12:56.541"
        end="00:12:58.958"><span region="Default">Membangkitkan<br/>kemarahan orang-orang buat melawan.</span></p>
      <p
        begin="00:12:59.041"
        end="00:13:01.666"><span region="Default">Si bangsat satu itu memang sumber masalah.</span></p>
      <p
        begin="00:13:01.750"
        end="00:13:03.541"><span region="Default">Dari semua warga Karang Setan,</span></p>
      <p
        begin="00:13:03.625"
        end="00:13:06.333"><span region="Default">cuma dia satu-satunya<br/>yang tidak mau jual tanahnya ke kita.</span></p>
      <p
        begin="00:13:06.416"
        end="00:13:08.458"><span region="Default">Masih ada satu lagi, Juragan,</span></p>
      <p
        begin="00:13:08.541"
        end="00:13:11.708"><span region="Default">tindakan yang akan dilakukan oleh Satrio</span></p>
      <p
        begin="00:13:11.791"
        end="00:13:14.041"><span region="Default">yang menurut saya sangat berbahaya.</span></p>
      <p
        begin="00:13:14.125"
        end="00:13:17.833"><span region="Default">Mencegah Juragan Bisman<br/>jadi lurah memang perlu.</span></p>
      <p
        begin="00:13:17.916"
        end="00:13:21.916"><span region="Default">Tapi kalau dia sudah<br/>melakukan kezoliman kepada kalian,</span></p>
      <p
        begin="00:13:22.583"
        end="00:13:26.625"><span region="Default">dan menyuruh anak buahnya melakukan<br/>tindak kekerasan terhadap kalian,</span></p>
      <p
        begin="00:13:26.708"
        end="00:13:31.083"><span region="Default">kenapa sampai saat ini tidak pernah ada<br/>yang melapor kepada polisi?</span></p>
      <p
        begin="00:13:31.166"
        end="00:13:34.166"><span region="Default">Itu sudah pernah kita lakukan, Pak Guru.</span></p>
      <p
        begin="00:13:34.250"
        end="00:13:36.208"><span region="Default">Tapi tidak ditanggapi.</span></p>
      <p
        begin="00:13:36.291"
        end="00:13:40.000"><span region="Default">Apa mungkin karena<br/>yang datang orang kecil seperti saya?</span></p>
      <p
        begin="00:13:40.083"
        end="00:13:43.791"><span region="Default">Kalau begitu sekalian kita<br/>minta tolong kepada Pak Guru.</span></p>
      <p
        begin="00:13:44.541"
        end="00:13:46.875"><span region="Default">Pergi ke kota buat lapor ke polisi.</span></p>
      <p
        begin="00:13:48.000"
        end="00:13:49.583"><span region="Default">Dia yakin</span></p>
      <p
        begin="00:13:49.666"
        end="00:13:53.291"><span region="Default">kalau polisi akan menutup tempat ini<br/>untuk selama-lamanya.</span></p>
      <p
        begin="00:14:42.083"
        end="00:14:44.125"><span region="Default">Malam yang mencekam.</span></p>
      <p
        begin="00:14:45.041"
        end="00:14:47.000"><span region="Default">Kutukan datang dari berbagai arah.</span></p>
      <p
        begin="00:14:47.083"
        end="00:14:51.000"><span region="Default">Jiwa yang tertekan, bertumpuk prasangka.</span></p>
      <p
        begin="00:14:51.083"
        end="00:14:55.416"><span region="Default">Tubuh yang penuh angkara setan hutan.</span></p>
      <p
        begin="00:14:55.500"
        end="00:14:59.291"><span region="Default">Datang dari utara, selatan, barat, timur.</span></p>
      <p
        begin="00:14:59.375"
        end="00:15:04.291"><span region="Default">Datanglah kepadaku<br/>pada malam saat gelap pekat.</span></p>
      <p
        begin="00:15:04.375"
        end="00:15:08.583"><span region="Default">Aku hambamu, aku persembahanmu.</span></p>
      <p
        begin="00:15:08.666"
        end="00:15:12.375"><span region="Default">Kuserahkan darah dan hidupku.</span></p>
      <p
        begin="00:15:19.375"
        end="00:15:20.666"><span region="Default">Minum.</span></p>
      <p
        begin="00:15:43.958"
        end="00:15:47.500"><span region="Default">Santet itu tertanam<br/>di pintu belakang rumahnya.</span></p>
      <p
        begin="00:15:49.625"
        end="00:15:51.125"><span region="Default">Namanya</span></p>
      <p
        begin="00:15:51.875"
        end="00:15:54.625"><span region="Default">santet samber nyowo.</span></p>
      <p
        begin="00:16:13.000"
        end="00:16:15.666"><span region="Default">Bu, ada apa?</span></p>
      <p
        begin="00:16:18.958"
        end="00:16:21.166"><span region="Default">Bu, si Manis mati!</span></p>
      <p
        begin="00:16:22.791"
        end="00:16:24.125"><span region="Default">Manis?</span></p>
      <p
        begin="00:16:24.208"
        end="00:16:27.250"><span region="Default">Aduh, panas! Panas!</span></p>
      <p
        begin="00:16:28.875"
        end="00:16:30.708"><span region="Default">Panas!</span></p>
      <p
        begin="00:16:30.791"
        end="00:16:33.833"><span region="Default">- Panas!<br/>- Bapak, kenapa, Pak?</span></p>
      <p
        begin="00:16:33.916"
        end="00:16:35.458"><span region="Default">Panas!</span></p>
      <p
        begin="00:16:35.541"
        end="00:16:37.583"><span region="Default">Bapak kenapa?</span></p>
      <p
        begin="00:16:37.666"
        end="00:16:39.208"><span region="Default">Aduh, panas, aduh!</span></p>
      <p
        begin="00:16:39.291"
        end="00:16:41.500"><span region="Default">Panas, panas!</span></p>
      <p
        begin="00:16:41.583"
        end="00:16:44.166"><span region="Default">- Panas!<br/>- Bapak kenapa?</span></p>
      <p
        begin="00:16:44.250"
        end="00:16:45.875"><span region="Default">Panas, panas!</span></p>
      <p
        begin="00:16:45.958"
        end="00:16:47.750"><span region="Default">Bapak kenapa?</span></p>
      <p
        begin="00:16:48.958"
        end="00:16:50.166"><span region="Default">Bapak?</span></p>
      <p
        begin="00:16:50.250"
        end="00:16:53.000"><span region="Default">Panas, perih, panas!</span></p>
      <p
        begin="00:16:53.083"
        end="00:16:54.791"><span region="Default">- Perih.<br/>- Pak!</span></p>
      <p
        begin="00:16:54.875"
        end="00:16:58.333"><span region="Default">Jangan Nduk, ini pasti kiriman santet.</span></p>
      <p
        begin="00:16:58.416"
        end="00:17:01.416"><span region="Default">- Santet?<br/>- Panas! Panas.</span></p>
      <p
        begin="00:17:01.500"
        end="00:17:02.791"><span region="Default">Aduh.</span></p>
      <p
        begin="00:17:04.041"
        end="00:17:05.500"><span region="Default">- Apa ini?<br/>- Bapak</span></p>
      <p
        begin="00:17:10.250"
        end="00:17:12.375"><span region="Default">Aduh, sakit!</span></p>
      <p
        begin="00:17:12.458"
        end="00:17:15.041"><span region="Default">Sakit, ini kenapa?</span></p>
      <p
        begin="00:17:15.125"
        end="00:17:16.166"><span region="Default">Pak…</span></p>
      <p
        begin="00:17:16.250"
        end="00:17:18.958"><span region="Default">Aduh sakit!</span></p>
      <p
        begin="00:17:21.916"
        end="00:17:23.166"><span region="Default">Aduh, aduh!</span></p>
      <p
        begin="00:17:26.125"
        end="00:17:27.125"><span region="Default">Aduh!</span></p>
      <p
        begin="00:17:28.916"
        end="00:17:30.875"><span region="Default">- Aduh!<br/>- Pak!</span></p>
      <p
        begin="00:17:34.083"
        end="00:17:37.583"><span region="Default">- Bapak!<br/>- Bapak!</span></p>
      <p
        begin="00:17:37.666"
        end="00:17:39.625"><span region="Default">- Bapak!<br/>- Pak!</span></p>
      <p
        begin="00:17:39.708"
        end="00:17:40.875"><span region="Default">- Pak?<br/>- Pak?</span></p>
      <p
        begin="00:17:40.958"
        end="00:17:42.708"><span region="Default">- Pak?<br/>- Bapak?</span></p>
      <p
        begin="00:17:43.708"
        end="00:17:46.625"><span region="Default">- Bapak!<br/>- Bapak…</span></p>
      <p
        begin="00:17:48.000"
        end="00:17:50.500"><span region="Default">Bapak…</span></p>
      <p
        begin="00:17:52.000"
        end="00:17:55.000"><span region="Default">Hidup Lurah Bisman!</span></p>
      <p
        begin="00:17:55.083"
        end="00:17:57.291"><span region="Default">Hidup!</span></p>
      <p
        begin="00:18:25.125"
        end="00:18:26.750"><span region="Default">Boss, tenang.</span></p>
      <p
        begin="00:18:34.208"
        end="00:18:35.416"><span region="Default">Juragan.</span></p>
      <p
        begin="00:18:39.125"
        end="00:18:40.208"><span region="Default">Ini, Gan.</span></p>
      <p
        begin="00:18:41.041"
        end="00:18:44.166"><span region="Default">Maaf tadi saya cari-cari<br/>sampai masuk kamar.</span></p>
      <p
        begin="00:18:44.250"
        end="00:18:45.625"><span region="Default">Di meja depan engga ada.</span></p>
      <p
        begin="00:18:45.708"
        end="00:18:47.791"><span region="Default">Kenapa kamu engga tanya istriku?</span></p>
      <p
        begin="00:18:48.375"
        end="00:18:49.791"><span region="Default">Bu Suroh tidak ada.</span></p>
      <p
        begin="00:18:51.625"
        end="00:18:56.500"><span region="Default">Kata pembantu, Ibu baru saja berangkat<br/>untuk tahlilan di rumah Suzzanna.</span></p>
      <p
        begin="00:18:57.083"
        end="00:18:58.000"><span region="Default">Apa?</span></p>
      <p
        begin="00:18:58.791"
        end="00:19:01.291"><span region="Default">Cepat kamu ke sana. Cegat Suroh.</span></p>
      <p
        begin="00:19:01.375"
        end="00:19:03.250"><span region="Default">Jangan sampai dia ketemu dengan Suzzanna.</span></p>
      <p
        begin="00:19:03.333"
        end="00:19:04.166"><span region="Default">Iya.</span></p>
      <p
        begin="00:19:04.250"
        end="00:19:07.250"><span region="Default">Dia pasti mengoceh macam-macam<br/>tentang kematian Satrio.</span></p>
      <p
        begin="00:19:07.833"
        end="00:19:08.666"><span region="Default">Baik, Gan.</span></p>
      <p
        begin="00:19:08.750"
        end="00:19:09.708"><span region="Default">Jangan sendirian.</span></p>
      <p
        begin="00:19:09.791"
        end="00:19:11.791"><span region="Default">Di sana pasti ramai.</span></p>
      <p
        begin="00:19:11.875"
        end="00:19:15.625"><span region="Default">Kalau ketemu dengan orang-orang<br/>yang gak suka sama kita, repot kamu.</span></p>
      <p
        begin="00:19:15.708"
        end="00:19:18.416"><span region="Default">- Ajak Banteng dan Lawu.<br/>- Baik, Gan.</span></p>
      <p
        begin="00:19:21.083"
        end="00:19:22.083"><span region="Default">Mana ibumu?</span></p>
      <p
        begin="00:19:22.916"
        end="00:19:26.416"><span region="Default">Sedang ke masjid.<br/>Antar makanan buat anak yatim, Bu.</span></p>
      <p
        begin="00:19:26.500"
        end="00:19:30.416"><span region="Default">Ya sudah. Saya bicara<br/>dengan Dek Suzzanna saja.</span></p>
      <p
        begin="00:19:31.083"
        end="00:19:32.625"><span region="Default">Biar hati saya lega.</span></p>
      <p
        begin="00:19:32.708"
        end="00:19:37.458"><span region="Default">Karena sampai akhirat pun<br/>saya akan merasa dikejar-kejar dosa</span></p>
      <p
        begin="00:19:38.125"
        end="00:19:42.750"><span region="Default">kalau saya ikut merahasiakan<br/>kezaliman yang kamu harus tahu.</span></p>
      <p
        begin="00:19:43.416"
        end="00:19:44.791"><span region="Default">Kezaliman apa, Bu?</span></p>
      <p
        begin="00:19:44.875"
        end="00:19:46.958"><span region="Default">Penyebab kematian bapakmu.</span></p>
      <p
        begin="00:19:56.125"
        end="00:20:00.041"><span region="Default">Dulu, Lurah Suroso dia kirimi santet.</span></p>
      <p
        begin="00:20:00.125"
        end="00:20:02.166"><span region="Default">Sampai sakit-sakitan dan meninggal.</span></p>
      <p
        begin="00:20:02.250"
        end="00:20:04.708"><span region="Default">Astaghfirullahaladzim.</span></p>
      <p
        begin="00:20:04.791"
        end="00:20:06.000"><span region="Default">Setelah itu,</span></p>
      <p
        begin="00:20:06.666"
        end="00:20:09.083"><span region="Default">ternyata ada pemilihan.</span></p>
      <p
        begin="00:20:09.166"
        end="00:20:13.583"><span region="Default">Dia harus bertarung melawan bapakmu<br/>yang disukai banyak orang.</span></p>
      <p
        begin="00:20:13.666"
        end="00:20:19.125"><span region="Default">Nasib bapakmu, Dek,<br/>tidak beda jauh sama Lurah Suroso.</span></p>
      <p
        begin="00:20:20.000"
        end="00:20:22.583"><span region="Default">Dibinasakan kiriman santet.</span></p>
      <p
        begin="00:20:24.416"
        end="00:20:25.708"><span region="Default">Ya Allah.</span></p>
      <p
        begin="00:20:36.583"
        end="00:20:38.708"><span region="Default">- Bu Suroh.<br/>- Mau apa kalian?</span></p>
      <p
        begin="00:20:39.375"
        end="00:20:41.958"><span region="Default">Maaf Bu, Ibu dicari-cari Bapak.</span></p>
      <p
        begin="00:20:42.625"
        end="00:20:46.291"><span region="Default">Tadi Bapak menyuruh kami<br/>untuk mencari dan menjemput Ibu.</span></p>
      <p
        begin="00:20:46.375"
        end="00:20:48.208"><span region="Default">Bilang sama juraganmu itu ya,</span></p>
      <p
        begin="00:20:48.791"
        end="00:20:50.583"><span region="Default">saya masih suka di sini.</span></p>
      <p
        begin="00:20:50.666"
        end="00:20:54.875"><span region="Default">Ya, kalau Ibu masih mau di sini silakan.</span></p>
      <p
        begin="00:20:54.958"
        end="00:20:58.416"><span region="Default">Tapi kami akan tetap di sini<br/>menunggu Ibu pulang.</span></p>
      <p
        begin="00:20:58.500"
        end="00:21:01.041"><span region="Default">Engga usah! Sekarang juga kalian pergi!</span></p>
      <p
        begin="00:21:03.583"
        end="00:21:04.666"><span region="Default">Banteng!</span></p>
      <p
        begin="00:21:05.375"
        end="00:21:09.041"><span region="Default">Sudah, engga usah bikin susah.<br/>Kami cuma menjalankan perintah.</span></p>
      <p
        begin="00:21:09.125"
        end="00:21:10.166"><span region="Default">Ayo pulang.</span></p>
      <p
        begin="00:21:11.500"
        end="00:21:12.791"><span region="Default">- Ayo ikut!<br/>- Apa sih?</span></p>
      <p
        begin="00:21:12.875"
        end="00:21:15.083"><span region="Default">- Pulang!<br/>- Heh! Kamu ini.</span></p>
      <p
        begin="00:21:18.125"
        end="00:21:22.250"><span region="Default">Kurang ajar kamu!<br/>Berani-beraninya kamu pegang istri orang.</span></p>
      <p
        begin="00:21:22.333"
        end="00:21:24.416"><span region="Default">Jadi istri kok galak kayak gini?</span></p>
      <p
        begin="00:21:24.500"
        end="00:21:26.916"><span region="Default">Pantas saja Juragan pengen kawin lagi.</span></p>
      <p
        begin="00:21:33.041"
        end="00:21:34.291"><span region="Default">Banteng!</span></p>
      <p
        begin="00:21:36.041"
        end="00:21:37.250"><span region="Default">Kurang ajar!</span></p>
      <p
        begin="00:21:40.291"
        end="00:21:42.500"><span region="Default">- Mau lari ke mana?<br/>- Lepasin!</span></p>
      <p
        begin="00:21:45.208"
        end="00:21:46.375"><span region="Default">Goblok!</span></p>
      <p
        begin="00:21:48.166"
        end="00:21:49.791"><span region="Default">Bu Suroh…</span></p>
      <p
        begin="00:21:58.416"
        end="00:21:59.666"><span region="Default">Heh.</span></p>
      <p
        begin="00:21:59.750"
        end="00:22:02.583"><span region="Default">Kalau sampai lapor juragan, mati kamu!</span></p>
      <p
        begin="00:22:29.791"
        end="00:22:31.333"><span region="Default">Ayo!</span></p>
      <p
        begin="00:23:57.500"
        end="00:24:00.833"><span region="Default">Mau lari ke mana lagi kamu?</span></p>
      <p
        begin="00:24:04.833"
        end="00:24:05.791"><span region="Default">Loncat?</span></p>
      <p
        begin="00:24:15.125"
        end="00:24:16.666"><span region="Default">Loncat!</span></p>
      <p
        begin="00:25:25.375"
        end="00:25:26.333"><span region="Default">Juragan.</span></p>
      <p
        begin="00:25:27.500"
        end="00:25:29.625"><span region="Default">Saya siap menerima hukuman.</span></p>
      <p
        begin="00:25:30.500"
        end="00:25:31.750"><span region="Default">Hukuman mati pun</span></p>
      <p
        begin="00:25:32.375"
        end="00:25:34.041"><span region="Default">saya bersedia…</span></p>
      <p
        begin="00:25:41.791"
        end="00:25:43.333"><span region="Default">Terus bagaimana dengan Suzzanna?</span></p>
      <p
        begin="00:25:48.500"
        end="00:25:51.208"><span region="Default">- Suzzanna…<br/>- Setelah melihat kondisi Bu Suroh,</span></p>
      <p
        begin="00:25:51.291"
        end="00:25:53.958"><span region="Default">Suzzanna ketakutan dan lari ke luar rumah.</span></p>
      <p
        begin="00:25:54.041"
        end="00:25:55.375"><span region="Default">Kami coba kejar,</span></p>
      <p
        begin="00:25:55.958"
        end="00:25:57.125"><span region="Default">tapi keburu hilang.</span></p>
      <p
        begin="00:25:57.916"
        end="00:25:58.958"><span region="Default">Kami coba cari.</span></p>
      <p
        begin="00:26:00.625"
        end="00:26:05.208"><span region="Default">Tapi kami putuskan<br/>untuk kembali ke rumah Suzzanna.</span></p>
      <p
        begin="00:26:05.291"
        end="00:26:07.500"><span region="Default">Untuk mengurus jenazah Bu Suroh.</span></p>
      <p
        begin="00:26:07.583"
        end="00:26:09.958"><span region="Default">Dia sudah tahu saya<br/>yang menyantet bapaknya?</span></p>
      <p
        begin="00:26:10.041"
        end="00:26:13.666"><span region="Default">Sepertinya… Bu Suroh<br/>belum sempat bercerita, Gan.</span></p>
      <p
        begin="00:26:15.291"
        end="00:26:17.041"><span region="Default">Cari Suzzanna.</span></p>
      <p
        begin="00:26:17.125"
        end="00:26:19.125"><span region="Default">Begitu dia muncul, laporkan ke saya.</span></p>
      <p
        begin="00:26:20.375"
        end="00:26:23.083"><span region="Default">Jangan sampai terjadi apa-apa<br/>dengan Suzzanna.</span></p>
      <p
        begin="00:26:23.708"
        end="00:26:24.625"><span region="Default">Baik, Juragan.</span></p>
      <p
        begin="00:27:35.708"
        end="00:27:37.333"><span region="Default">Hancur lebur.</span></p>
      <p
        begin="00:27:40.208"
        end="00:27:43.291"><span region="Default">Ini retak. Ini ada luka dalam.</span></p>
      <p
        begin="00:27:45.041"
        end="00:27:46.750"><span region="Default">Ketusuk patahan juga.</span></p>
      <p
        begin="00:27:46.833"
        end="00:27:48.958"><span region="Default">Tapi belum mati dia.</span></p>
      <p
        begin="00:27:55.208"
        end="00:27:56.375"><span region="Default">Lek.</span></p>
      <p
        begin="00:27:57.750"
        end="00:28:01.958"><span region="Default">Kamu tunggu<br/>sampai dia sembuh, ya? Kasihan.</span></p>
      <p
        begin="00:28:03.791"
        end="00:28:06.458"><span region="Default">Bude bisa menyembuhkan luka dalamnya.</span></p>
      <p
        begin="00:28:07.916"
        end="00:28:09.666"><span region="Default">Kamu yang menggarap luarnya.</span></p>
      <p
        begin="00:28:11.916"
        end="00:28:13.250"><span region="Default">Iya, Bude.</span></p>
      <p
        begin="00:29:45.166"
        end="00:29:48.000"><span region="Default">Kemauannya untuk hidup masih besar.</span></p>
      <p
        begin="00:29:49.250"
        end="00:29:50.416"><span region="Default">Lek?</span></p>
      <p
        begin="00:30:02.583"
        end="00:30:04.208"><span region="Default">Betul yang dikatakan Bude.</span></p>
      <p
        begin="00:30:05.583"
        end="00:30:06.958"><span region="Default">Tiga minggu baru sadar.</span></p>
      <p
        begin="00:30:12.291"
        end="00:30:14.083"><span region="Default">Jangan bangun dulu.</span></p>
      <p
        begin="00:30:15.125"
        end="00:30:17.500"><span region="Default">Tulang-tulangmu masih belum kuat.</span></p>
      <p
        begin="00:30:17.583"
        end="00:30:18.750"><span region="Default">Istirahat.</span></p>
      <p
        begin="00:30:24.958"
        end="00:30:26.333"><span region="Default">Aku di mana?</span></p>
      <p
        begin="00:30:26.416"
        end="00:30:27.958"><span region="Default">Di rumahku.</span></p>
      <p
        begin="00:30:28.708"
        end="00:30:30.625"><span region="Default">Desa Kalinegoro.</span></p>
      <p
        begin="00:30:32.041"
        end="00:30:34.333"><span region="Default">Ini Pramuja keponakanku.</span></p>
      <p
        begin="00:30:35.416"
        end="00:30:38.000"><span region="Default">Keponakanku yang menolongmu.</span></p>
      <p
        begin="00:30:43.875"
        end="00:30:46.041"><span region="Default">Siapa namamu, Nduk?</span></p>
      <p
        begin="00:30:46.125"
        end="00:30:47.541"><span region="Default">Suzzanna.</span></p>
      <p
        begin="00:30:48.375"
        end="00:30:49.750"><span region="Default">Suzzanna.</span></p>
      <p
        begin="00:30:51.250"
        end="00:30:53.250"><span region="Default">Aku Gayatri.</span></p>
      <p
        begin="00:30:53.333"
        end="00:30:55.166"><span region="Default">Aku Bawuk.</span></p>
      <p
        begin="00:31:29.458"
        end="00:31:30.500"><span region="Default">Pelan.</span></p>
      <p
        begin="00:31:46.166"
        end="00:31:47.500"><span region="Default">Kakimu sudah kuat?</span></p>
      <p
        begin="00:31:48.583"
        end="00:31:50.583"><span region="Default">Berkat kamu dan Nyai, Mas.</span></p>
      <p
        begin="00:31:52.375"
        end="00:31:54.375"><span region="Default">- Aku bantu?<br/>- Tidak usah.</span></p>
      <p
        begin="00:31:55.791"
        end="00:31:58.416"><span region="Default">Saya bisa. Kamu duduk saja.</span></p>
      <p
        begin="00:32:06.833"
        end="00:32:09.833"><span region="Default">Mungkin kamu tidak ingat<br/>tapi kita pernah bertemu.</span></p>
      <p
        begin="00:32:20.208"
        end="00:32:21.375"><span region="Default">Biar saya bantu.</span></p>
      <p
        begin="00:32:32.458"
        end="00:32:33.458"><span region="Default">Aku ingat.</span></p>
      <p
        begin="00:32:46.708"
        end="00:32:48.625"><span region="Default">Tangannya masih sakit, Bude.</span></p>
      <p
        begin="00:32:49.500"
        end="00:32:50.625"><span region="Default">Jadi saya bantu.</span></p>
      <p
        begin="00:32:51.375"
        end="00:32:53.458"><span region="Default">Ya dibantu saja, Lek.</span></p>
      <p
        begin="00:33:17.125"
        end="00:33:19.083"><span region="Default">- Ambil jemuran dulu, Mas.<br/>- Biar saya.</span></p>
      <p
        begin="00:33:32.833"
        end="00:33:34.208"><span region="Default">Sebentar.</span></p>
      <p
        begin="00:33:35.708"
        end="00:33:38.750"><span region="Default">Dia sudah menyakiti<br/>saya puluhan tahun, Nyai.</span></p>
      <p
        begin="00:33:40.125"
        end="00:33:42.000"><span region="Default">Saya sudah engga kuat.</span></p>
      <p
        begin="00:33:44.166"
        end="00:33:48.041"><span region="Default">Anak-anakku juga<br/>sekarang ikut menerima pukulannya.</span></p>
      <p
        begin="00:33:50.333"
        end="00:33:53.125"><span region="Default">Saya engga bisa<br/>membiarkan ini lebih lama lagi.</span></p>
      <p
        begin="00:33:54.000"
        end="00:33:56.166"><span region="Default">Lalu apa yang bisa saya bantu?</span></p>
      <p
        begin="00:33:56.833"
        end="00:33:58.458"><span region="Default">Tolong pulangkan suami saya, Nyai.</span></p>
      <p
        begin="00:33:59.291"
        end="00:34:00.458"><span region="Default">Pulangkan?</span></p>
      <p
        begin="00:34:01.041"
        end="00:34:02.750"><span region="Default">Pulangkan ke mana?</span></p>
      <p
        begin="00:34:03.416"
        end="00:34:05.000"><span region="Default">Pulangkan kepada Gusti Allah.</span></p>
      <p
        begin="00:35:05.166"
        end="00:35:06.333"><span region="Default">Pramuja.</span></p>
      <p
        begin="00:35:10.125"
        end="00:35:12.833"><span region="Default">- Apa ini Bude?<br/>- Bude sudah bilang.</span></p>
      <p
        begin="00:35:12.916"
        end="00:35:14.916"><span region="Default">Jangan pernah masuk ke sini.</span></p>
      <p
        begin="00:35:16.458"
        end="00:35:18.958"><span region="Default">Selama ini saya berpikir Bude<br/>hanya menjalankan ilmu pengobatan</span></p>
      <p
        begin="00:35:19.041"
        end="00:35:21.000"><span region="Default">tapi ini, ini semua…</span></p>
      <p
        begin="00:35:27.958"
        end="00:35:29.750"><span region="Default">- Kamu kecewa?<br/>- Saya…</span></p>
      <p
        begin="00:35:31.416"
        end="00:35:33.500"><span region="Default">Kalau begitu sebaiknya kamu pergi.</span></p>
      <p
        begin="00:35:34.291"
        end="00:35:37.083"><span region="Default">- Dan jangan tinggal di sini lagi.<br/>- Tapi…</span></p>
      <p
        begin="00:36:30.500"
        end="00:36:33.458"><span region="Default">Mohon diampunkan<br/>kesalahan dan kelancangan saya ini, Nyi.</span></p>
      <p
        begin="00:36:33.541"
        end="00:36:35.833"><span region="Default">Tapi dia memaksa masuk.</span></p>
      <p
        begin="00:36:35.916"
        end="00:36:37.500"><span region="Default">Maksudmu apa?</span></p>
      <p
        begin="00:36:46.125"
        end="00:36:48.750"><span region="Default">Izinkanlah saya belajar ilmu, Nyi.</span></p>
      <p
        begin="00:36:50.458"
        end="00:36:54.583"><span region="Default">Agar saya bisa membalas<br/>manusia-manusia jahat yang menzalimi saya.</span></p>
      <p
        begin="00:36:55.708"
        end="00:36:56.875"><span region="Default">Nduk.</span></p>
      <p
        begin="00:36:58.291"
        end="00:37:01.541"><span region="Default">Memangnya kamu<br/>tidak takut sama Gusti Allah?</span></p>
      <p
        begin="00:37:01.625"
        end="00:37:03.375"><span region="Default">Kenapa Nyi bertanya begitu?</span></p>
      <p
        begin="00:37:06.291"
        end="00:37:07.458"><span region="Default">Nduk, Nduk.</span></p>
      <p
        begin="00:37:07.541"
        end="00:37:10.291"><span region="Default">Aku tahu apa yang kamu inginkan.</span></p>
      <p
        begin="00:37:11.083"
        end="00:37:15.291"><span region="Default">Aku juga sangat tahu, Nduk,<br/>begitu kamu mulai belajar,</span></p>
      <p
        begin="00:37:15.375"
        end="00:37:17.958"><span region="Default">saat itu juga kamu sudah harus siap</span></p>
      <p
        begin="00:37:18.041"
        end="00:37:20.958"><span region="Default">menjadi penghuni<br/>kerak neraka paling dalam, Nduk.</span></p>
      <p
        begin="00:37:22.708"
        end="00:37:24.041"><span region="Default">Buat saya,</span></p>
      <p
        begin="00:37:24.958"
        end="00:37:28.333"><span region="Default">api neraka itu ada di<br/>Dusun Karang Setan, Nyi.</span></p>
      <p
        begin="00:37:32.541"
        end="00:37:33.958"><span region="Default">Dan saya…</span></p>
      <p
        begin="00:37:35.250"
        end="00:37:38.416"><span region="Default">akan berusaha<br/>dengan kekuatan yang saya miliki</span></p>
      <p
        begin="00:37:38.500"
        end="00:37:42.750"><span region="Default">untuk memadamkannya, Nyi.<br/>Meskipun saya yang harus terbakar.</span></p>
      <p
        begin="00:37:45.375"
        end="00:37:47.666"><span region="Default">Sebegitu besar tekadmu, Nduk?</span></p>
      <p
        begin="00:37:48.416"
        end="00:37:51.708"><span region="Default">Karena saya tidak tahu lagi<br/>ke mana harus minta pertolongan, Nyi.</span></p>
      <p
        begin="00:37:55.125"
        end="00:37:57.208"><span region="Default">Saya harus menyelamatkan Ibu.</span></p>
      <p
        begin="00:37:59.208"
        end="00:38:00.333"><span region="Default">Ayo, Nduk.</span></p>
      <p
        begin="00:38:10.916"
        end="00:38:14.666"><span region="Default">Sebetulnya sudah lama aku mencari orang</span></p>
      <p
        begin="00:38:14.750"
        end="00:38:17.125"><span region="Default">yang aku anggap layak<br/>untuk mewarisi ilmuku.</span></p>
      <p
        begin="00:38:18.208"
        end="00:38:20.333"><span region="Default">Kupikir Pramuja bisa.</span></p>
      <p
        begin="00:38:22.000"
        end="00:38:25.750"><span region="Default">Tapi ternyata dia<br/>hanya ingin mempelajari ilmu pengobatan.</span></p>
      <p
        begin="00:38:26.708"
        end="00:38:28.500"><span region="Default">Buat dia, hal-hal seperti ini</span></p>
      <p
        begin="00:38:29.083"
        end="00:38:30.833"><span region="Default">adalah kemusyrikan.</span></p>
      <p
        begin="00:38:34.250"
        end="00:38:36.625"><span region="Default">Lalu kamu muncul, Nduk.</span></p>
      <p
        begin="00:38:38.958"
        end="00:38:41.875"><span region="Default">Mata batinku langsung bisa melihat</span></p>
      <p
        begin="00:38:41.958"
        end="00:38:43.958"><span region="Default">kalau kamu punya kemampuan</span></p>
      <p
        begin="00:38:44.041"
        end="00:38:47.375"><span region="Default">yang akan memudahkanmu<br/>untuk menyerap ilmu yang kumiliki.</span></p>
      <p
        begin="00:38:48.041"
        end="00:38:49.416"><span region="Default">Kemampuan apa, Nyi?</span></p>
      <p
        begin="00:38:54.541"
        end="00:38:56.041"><span region="Default">Kamu lihat Bawuk?</span></p>
      <p
        begin="00:38:58.166"
        end="00:38:59.291"><span region="Default">Iya.</span></p>
      <p
        begin="00:38:59.375"
        end="00:39:03.750"><span region="Default">Kamu pernah lihat<br/>Pramuja bicara sama Bawuk?</span></p>
      <p
        begin="00:39:07.375"
        end="00:39:10.000"><span region="Default">Pramuja tidak bisa melihat Bawuk.</span></p>
      <p
        begin="00:39:10.666"
        end="00:39:12.083"><span region="Default">Tapi kamu bisa.</span></p>
      <p
        begin="00:39:12.166"
        end="00:39:15.333"><span region="Default">Bawuk sebetulnya adalah seorang jin</span></p>
      <p
        begin="00:39:15.416"
        end="00:39:18.750"><span region="Default">yang menumpang tinggal di rumah ini.</span></p>
      <p
        begin="00:39:20.416"
        end="00:39:24.208"><span region="Default">Mati surimu yang hampir sebulan kemarin,</span></p>
      <p
        begin="00:39:24.291"
        end="00:39:26.750"><span region="Default">nampaknya mengasah kemampuanmu.</span></p>
      <p
        begin="00:39:28.375"
        end="00:39:29.958"><span region="Default">Dan dengan kemampuan ini</span></p>
      <p
        begin="00:39:30.041"
        end="00:39:31.625"><span region="Default">aku yakin, Nduk.</span></p>
      <p
        begin="00:39:32.833"
        end="00:39:37.041"><span region="Default">Kamu akan dengan mudah<br/>mempelajari ilmu yang akan aku ajarkan.</span></p>
      <p
        begin="00:39:37.833"
        end="00:39:39.000"><span region="Default">Pertama-tama,</span></p>
      <p
        begin="00:39:39.083"
        end="00:39:42.291"><span region="Default">kamu harus menjalani puasa mutih.</span></p>
      <p
        begin="00:39:42.958"
        end="00:39:45.958"><span region="Default">Selama 7 hari 7 malam.</span></p>
      <p
        begin="00:39:46.041"
        end="00:39:50.375"><span region="Default">Dan selama itu kamu harus tetap berdiri.</span></p>
      <p
        begin="00:39:50.458"
        end="00:39:52.750"><span region="Default">Dan tidak boleh tidur.</span></p>
      <p
        begin="00:39:53.458"
        end="00:39:58.875"><span region="Default">Selesai puasa mutih, kamu<br/>harus direndam di pesisir Laut Selatan</span></p>
      <p
        begin="00:39:58.958"
        end="00:40:02.166"><span region="Default">sambil tidak putus-putus merapal doa.</span></p>
      <p
        begin="00:40:02.250"
        end="00:40:06.333"><span region="Default">Agar siap menerima ilmu<br/>yang kamu inginkan.</span></p>
      <p
        begin="00:40:06.416"
        end="00:40:11.500"><span region="Default">Dan yang paling memerlukan kekuatan<br/>dan ketahanan jiwa ragamu ialah</span></p>
      <p
        begin="00:40:11.583"
        end="00:40:14.750"><span region="Default">bersemedi selama 40 hari</span></p>
      <p
        begin="00:40:14.833"
        end="00:40:16.833"><span region="Default">40 malam.</span></p>
      <p
        begin="00:41:01.291"
        end="00:41:03.125"><span region="Default">Sampai suatu saat</span></p>
      <p
        begin="00:41:04.208"
        end="00:41:08.458"><span region="Default">kamu akan menemukan perewangan<br/>yang berjodoh denganmu.</span></p>
      <p
        begin="00:41:10.333"
        end="00:41:13.250"><span region="Default">Yang akan selalu siap membantumu.</span></p>
      <p
        begin="00:41:14.708"
        end="00:41:18.250"><span region="Default">Menjalankan semua<br/>perintah dan permintaanmu.</span></p>
      <p
        begin="00:41:18.333"
        end="00:41:19.708"><span region="Default">Asal</span></p>
      <p
        begin="00:41:20.625"
        end="00:41:24.416"><span region="Default">kamu kasih dia persembahan<br/>sesuai keinginannya.</span></p>
      <p
        begin="00:41:27.250"
        end="00:41:31.833"><span region="Default">Simpanlah dan bawalah pusaka milikmu itu<br/>ke mana pun kamu pergi.</span></p>
      <p
        begin="00:41:31.916"
        end="00:41:33.625"><span region="Default">Karena di situlah</span></p>
      <p
        begin="00:41:34.333"
        end="00:41:39.750"><span region="Default">perewanganmu akan singgah<br/>setiap kamu memerlukan bantuannya.</span></p>
      <p
        begin="00:41:45.416"
        end="00:41:46.333"><span region="Default">Selamat siang, Pak Lurah.</span></p>
      <p
        begin="00:41:47.583"
        end="00:41:48.458"><span region="Default">Selamat siang.</span></p>
      <p
        begin="00:41:54.250"
        end="00:41:55.708"><span region="Default">Apa yang bisa saya bantu?</span></p>
      <p
        begin="00:41:56.750"
        end="00:42:00.041"><span region="Default">Begini, Pak Lurah,<br/>maksud dan tujuan saya datang kemari</span></p>
      <p
        begin="00:42:00.125"
        end="00:42:03.416"><span region="Default">saya mau mencari tahu tentang seseorang<br/>yang pernah tinggal di sini.</span></p>
      <p
        begin="00:42:03.500"
        end="00:42:06.916"><span region="Default">Namanya Kasman Wironegoro.</span></p>
      <p
        begin="00:42:08.875"
        end="00:42:12.250"><span region="Default">Kamu nyari orang<br/>yang namanya Kasman? Ada urusan apa?</span></p>
      <p
        begin="00:42:14.250"
        end="00:42:15.875"><span region="Default">Beliau bapak saya.</span></p>
      <p
        begin="00:42:19.583"
        end="00:42:22.625"><span region="Default">Saya tidak punya fotonya<br/>tapi saya punya foto ibu saya.</span></p>
      <p
        begin="00:42:26.208"
        end="00:42:28.125"><span region="Default">Bapakmu itu orang biadab.</span></p>
      <p
        begin="00:42:29.041"
        end="00:42:32.583"><span region="Default">Dia pernah menghamili perempuan<br/>sampai diusir dari desa ini.</span></p>
      <p
        begin="00:42:40.750"
        end="00:42:44.125"><span region="Default">Maaf Pak Lurah. Tapi apa<br/>Bapak tahu di mana bapak saya?</span></p>
      <p
        begin="00:42:44.208"
        end="00:42:46.500"><span region="Default">Atau setidaknya rumah beliau?</span></p>
      <p
        begin="00:42:46.583"
        end="00:42:48.166"><span region="Default">Bapakmu itu sudah mati.</span></p>
      <p
        begin="00:42:55.458"
        end="00:42:57.625"><span region="Default">- Kopi apa kencing kuda ini?<br/>- Kopi, Juragan.</span></p>
      <p
        begin="00:42:57.708"
        end="00:42:59.083"><span region="Default">Dijawab lagi!</span></p>
      <p
        begin="00:43:10.166"
        end="00:43:11.416"><span region="Default">Saya permisi.</span></p>
      <p
        begin="00:43:21.166"
        end="00:43:23.166"><span region="Default">Siapa tadi yang bikin kopi buat Pak Lurah?</span></p>
      <p
        begin="00:43:23.833"
        end="00:43:25.250"><span region="Default">Saya.</span></p>
      <p
        begin="00:43:25.916"
        end="00:43:27.583"><span region="Default">Itu kopi apa kencing kuda?</span></p>
      <p
        begin="00:43:29.375"
        end="00:43:30.541"><span region="Default">Lah, ya kopi.</span></p>
      <p
        begin="00:43:30.625"
        end="00:43:31.833"><span region="Default">Bikin lagi yang enak.</span></p>
      <p
        begin="00:43:31.916"
        end="00:43:33.125"><span region="Default">Pak Lurahnya 'kan udah pergi?</span></p>
      <p
        begin="00:43:33.208"
        end="00:43:35.875"><span region="Default">Bikin lagi buat gue sama Tohir sama Diran.</span></p>
      <p
        begin="00:43:36.791"
        end="00:43:38.041"><span region="Default">Aduh.</span></p>
      <p
        begin="00:43:42.958"
        end="00:43:44.208"><span region="Default">Susah.</span></p>
      <p
        begin="00:43:44.833"
        end="00:43:47.791"><span region="Default">Kalo jongos diangkat jadi pejabat,<br/>gayanya selangit.</span></p>
      <p
        begin="00:43:48.666"
        end="00:43:50.208"><span region="Default">Aneh.</span></p>
      <p
        begin="00:44:05.958"
        end="00:44:07.916"><span region="Default">Memang mau buat apa?</span></p>
      <p
        begin="00:44:08.000"
        end="00:44:09.291"><span region="Default">Jamu kuat.</span></p>
      <p
        begin="00:44:29.833"
        end="00:44:31.833"><span region="Default">Maaf, ini kopinya udah saya ganti.</span></p>
      <p
        begin="00:44:44.500"
        end="00:44:46.125"><span region="Default">Lu tambahin apa ini kopi?</span></p>
      <p
        begin="00:44:48.000"
        end="00:44:49.875"><span region="Default">Kebetulan ada bubuk pala,</span></p>
      <p
        begin="00:44:49.958"
        end="00:44:51.625"><span region="Default">saya aduk-aduk, coba-coba.</span></p>
      <p
        begin="00:44:53.750"
        end="00:44:56.541"><span region="Default">Ini baru kopi!</span></p>
      <p
        begin="00:44:59.750"
        end="00:45:00.750"><span region="Default">Cobain, Hir.</span></p>
      <p
        begin="00:45:09.125"
        end="00:45:10.750"><span region="Default">Luar biasa!</span></p>
      <p
        begin="00:45:13.083"
        end="00:45:14.375"><span region="Default">Cobain, Ran.</span></p>
      <p
        begin="00:45:20.458"
        end="00:45:21.791"><span region="Default">Kok, kayak kencing kuda?</span></p>
      <p
        begin="00:45:24.208"
        end="00:45:26.166"><span region="Default">Lu mah engga ngerti kopi.</span></p>
      <p
        begin="00:45:26.250"
        end="00:45:27.500"><span region="Default">Sini buat gue aja.</span></p>
      <p
        begin="00:45:27.583"
        end="00:45:31.125"><span region="Default">Besok, lu bikin lagi kayak gini, ya?</span></p>
      <p
        begin="00:45:31.208"
        end="00:45:32.250"><span region="Default">Baik, Bang.</span></p>
      <p
        begin="00:45:48.833"
        end="00:45:49.958"><span region="Default">Bu?</span></p>
      <p
        begin="00:46:10.333"
        end="00:46:11.500"><span region="Default">Bu?</span></p>
      <p
        begin="00:46:18.833"
        end="00:46:19.750"><span region="Default">Bu?</span></p>
      <p
        begin="00:46:21.666"
        end="00:46:22.666"><span region="Default">Bu.</span></p>
      <p
        begin="00:46:28.458"
        end="00:46:29.500"><span region="Default">Bu?</span></p>
      <p
        begin="00:46:33.708"
        end="00:46:35.458"><span region="Default">Ibu panas sekali.</span></p>
      <p
        begin="00:46:35.541"
        end="00:46:37.750"><span region="Default">Sudah lama, Nduk.</span></p>
      <p
        begin="00:46:38.583"
        end="00:46:40.250"><span region="Default">Kadang demam.</span></p>
      <p
        begin="00:46:41.500"
        end="00:46:42.958"><span region="Default">Kadang hilang.</span></p>
      <p
        begin="00:46:43.833"
        end="00:46:45.583"><span region="Default">Mata Ibu kenapa?</span></p>
      <p
        begin="00:46:46.458"
        end="00:46:48.250"><span region="Default">Setelah kamu</span></p>
      <p
        begin="00:46:49.416"
        end="00:46:51.250"><span region="Default">pergi menghilang…</span></p>
      <p
        begin="00:46:53.416"
        end="00:46:57.000"><span region="Default">Tiga preman anak buah Bisman</span></p>
      <p
        begin="00:46:57.083"
        end="00:47:00.666"><span region="Default">hampir tiap hari datang.</span></p>
      <p
        begin="00:47:00.750"
        end="00:47:05.041"><span region="Default">Ibu sampai hapal nama mereka.</span></p>
      <p
        begin="00:47:05.125"
        end="00:47:09.500"><span region="Default">Banteng, Lawu, Kawi.</span></p>
      <p
        begin="00:47:09.583"
        end="00:47:13.208"><span region="Default">Datang setiap pagi, minta sarapan.</span></p>
      <p
        begin="00:47:13.291"
        end="00:47:17.833"><span region="Default">Siang, malam, datang lagi.</span></p>
      <p
        begin="00:47:17.916"
        end="00:47:22.333"><span region="Default">Sambil mereka mabuk-mabukan.</span></p>
      <p
        begin="00:47:23.333"
        end="00:47:28.375"><span region="Default">Kalau mereka engga suka makanan Ibu,</span></p>
      <p
        begin="00:47:28.458"
        end="00:47:30.166"><span region="Default">mereka ngamuk.</span></p>
      <p
        begin="00:47:40.291"
        end="00:47:42.208"><span region="Default">Manusia-manusia biadab.</span></p>
      <p
        begin="00:47:46.458"
        end="00:47:49.291"><span region="Default">Mereka harus dihukum seberat-beratnya.</span></p>
      <p
        begin="00:47:49.958"
        end="00:47:53.000"><span region="Default">Kita tidak kuat</span></p>
      <p
        begin="00:47:54.500"
        end="00:47:59.208"><span region="Default">melawan mereka yang berkuasa.</span></p>
      <p
        begin="00:48:01.750"
        end="00:48:03.125"><span region="Default">Kamu…</span></p>
      <p
        begin="00:48:04.625"
        end="00:48:08.375"><span region="Default">lebih baik pergi dari kampung ini.</span></p>
      <p
        begin="00:48:09.208"
        end="00:48:10.125"><span region="Default">Nduk.</span></p>
      <p
        begin="00:48:12.125"
        end="00:48:15.125"><span region="Default">Ibu sudah engga kuat.</span></p>
      <p
        begin="00:48:15.750"
        end="00:48:17.791"><span region="Default">Ingat ya, Nduk.</span></p>
      <p
        begin="00:48:17.875"
        end="00:48:21.500"><span region="Default">Makamkan Ibu</span></p>
      <p
        begin="00:48:22.250"
        end="00:48:25.708"><span region="Default">disamping bapakmu.</span></p>
      <p
        begin="00:48:35.916"
        end="00:48:37.000"><span region="Default">Bu…</span></p>
      <p
        begin="00:48:39.166"
        end="00:48:41.250"><span region="Default">Yang sabar ya, Nak.</span></p>
      <p
        begin="00:49:03.208"
        end="00:49:04.416"><span region="Default">Suzzanna?</span></p>
      <p
        begin="00:49:09.750"
        end="00:49:11.583"><span region="Default">Kenapa kamu ada di sini?</span></p>
      <p
        begin="00:49:11.666"
        end="00:49:13.083"><span region="Default">Saya…</span></p>
      <p
        begin="00:49:13.875"
        end="00:49:17.083"><span region="Default">sedang mencari nisan bapak saya.</span></p>
      <p
        begin="00:49:17.166"
        end="00:49:21.125"><span region="Default">Saya mendapat kabar ada kemungkinan<br/>bapak saya sudah meninggal.</span></p>
      <p
        begin="00:49:23.208"
        end="00:49:24.916"><span region="Default">Ibuku meninggal, Mas.</span></p>
      <p
        begin="00:49:25.500"
        end="00:49:27.916"><span region="Default">Innalillahi wa inna ilaihi rojiun.</span></p>
      <p
        begin="00:49:28.000"
        end="00:49:30.666"><span region="Default">Suzzanna. Saya turut berduka.</span></p>
      <p
        begin="00:49:32.125"
        end="00:49:33.625"><span region="Default">Terima kasih.</span></p>
      <p
        begin="00:49:34.250"
        end="00:49:35.625"><span region="Default">Kalau…</span></p>
      <p
        begin="00:49:37.708"
        end="00:49:39.250"><span region="Default">kamu membutuhkan saya,</span></p>
      <p
        begin="00:49:40.208"
        end="00:49:42.041"><span region="Default">kamu bisa menemui saya di masjid.</span></p>
      <p
        begin="00:49:42.916"
        end="00:49:44.708"><span region="Default">Dekat dari sini.</span></p>
      <p
        begin="00:49:44.791"
        end="00:49:46.416"><span region="Default">Sementara saya tinggal di situ.</span></p>
      <p
        begin="00:49:47.458"
        end="00:49:48.833"><span region="Default">Terima kasih, Mas.</span></p>
      <p
        begin="00:50:00.250"
        end="00:50:01.208"><span region="Default">Yang tabah.</span></p>
      <p
        begin="00:50:21.583"
        end="00:50:22.750"><span region="Default">Suzzanna.</span></p>
      <p
        begin="00:50:23.291"
        end="00:50:26.583"><span region="Default">Saya sedih sekali kita<br/>ketemu dalam suasana duka.</span></p>
      <p
        begin="00:50:26.666"
        end="00:50:29.791"><span region="Default">Atas nama jajaran<br/>pengurus kelurahan Karang Setan,</span></p>
      <p
        begin="00:50:30.416"
        end="00:50:33.000"><span region="Default">kami mengucapkan bela sungkawa<br/>yang sedalam-dalamnya</span></p>
      <p
        begin="00:50:33.083"
        end="00:50:34.666"><span region="Default">atas meninggalnya Ibu Sutini.</span></p>
      <p
        begin="00:50:37.208"
        end="00:50:38.916"><span region="Default">Terima kasih, Juragan.</span></p>
      <p
        begin="00:50:39.000"
        end="00:50:40.625"><span region="Default">Jangan panggil saya Juragan.</span></p>
      <p
        begin="00:50:42.041"
        end="00:50:44.458"><span region="Default">Sebut saja Pak Lurah. Atau Bisman.</span></p>
      <p
        begin="00:50:45.875"
        end="00:50:48.666"><span region="Default">Terima kasih, Bisman.</span></p>
      <p
        begin="00:50:49.708"
        end="00:50:51.416"><span region="Default">Kamu ke mana saja, Suzzanna?</span></p>
      <p
        begin="00:50:52.375"
        end="00:50:53.875"><span region="Default">Semenjak Bapak tidak ada,</span></p>
      <p
        begin="00:50:54.625"
        end="00:50:56.166"><span region="Default">kamu menghilang begitu saja.</span></p>
      <p
        begin="00:51:08.000"
        end="00:51:10.041"><span region="Default">Izinkan saya melamarmu, Suzzanna.</span></p>
      <p
        begin="00:51:21.583"
        end="00:51:23.416"><span region="Default">Saya mau menerima lamarannya</span></p>
      <p
        begin="00:51:24.166"
        end="00:51:26.750"><span region="Default">setelah sepenuhnya batin saya tenang.</span></p>
      <p
        begin="00:51:27.833"
        end="00:51:30.958"><span region="Default">Dan batin saya bisa tenang<br/>setelah saya tahu pasti</span></p>
      <p
        begin="00:51:31.541"
        end="00:51:34.416"><span region="Default">Siapa yang menyuruh menyantet bapak saya.</span></p>
      <p
        begin="00:51:36.875"
        end="00:51:39.958"><span region="Default">Dan kalau Pak Bisman<br/>bisa menangkap orang itu,</span></p>
      <p
        begin="00:51:40.541"
        end="00:51:43.958"><span region="Default">membawanya ke hadapan saya<br/>dalam keadaan tak berdaya,</span></p>
      <p
        begin="00:51:47.833"
        end="00:51:49.666"><span region="Default">saya juga baru bisa tenang,</span></p>
      <p
        begin="00:51:49.750"
        end="00:51:53.083"><span region="Default">setelah Pak Bisman<br/>menghukum ketiga anak buah Bapak,</span></p>
      <p
        begin="00:51:53.583"
        end="00:51:56.125"><span region="Default">yang tega menzalimi Ibu</span></p>
      <p
        begin="00:51:56.208"
        end="00:51:58.291"><span region="Default">sampai sakit dan meninggal dunia.</span></p>
      <p
        begin="00:51:59.333"
        end="00:52:00.666"><span region="Default">Mereka jugalah</span></p>
      <p
        begin="00:52:01.416"
        end="00:52:04.583"><span region="Default">yang sudah mengejar-ngejar saya<br/>sampai akhirnya saya jatuh ke jurang.</span></p>
      <p
        begin="00:52:05.500"
        end="00:52:07.833"><span region="Default">Dan mati suri hampir sebulan lamanya.</span></p>
      <p
        begin="00:52:11.708"
        end="00:52:14.250"><span region="Default">Kalau Bapak bisa membereskan itu semua,</span></p>
      <p
        begin="00:52:15.291"
        end="00:52:16.500"><span region="Default">lamaran Bapak saya terima.</span></p>
      <p
        begin="00:52:28.291"
        end="00:52:32.208"><span region="Default">Pasti juragan bakal nyuruh Lesus<br/>buat nyantet kita bertiga.</span></p>
      <p
        begin="00:52:33.333"
        end="00:52:34.416"><span region="Default">Engga mungkin.</span></p>
      <p
        begin="00:52:35.583"
        end="00:52:38.125"><span region="Default">Kita sama Juragan Bisman, 'kan bersaudara.</span></p>
      <p
        begin="00:52:38.208"
        end="00:52:41.041"><span region="Default">Masa sesama saudara ngirim santet?</span></p>
      <p
        begin="00:52:41.125"
        end="00:52:43.833"><span region="Default">Saudara dari mana, Lawu?</span></p>
      <p
        begin="00:52:44.583"
        end="00:52:48.000"><span region="Default">Juragan Bisman selalu bilang<br/>kita saudara itu cuma basa basi.</span></p>
      <p
        begin="00:52:48.083"
        end="00:52:52.666"><span region="Default">Supaya kita merasa<br/>dekat sama dia. Setia sama dia.</span></p>
      <p
        begin="00:52:52.750"
        end="00:52:54.250"><span region="Default">Bukan saudara beneran!</span></p>
      <p
        begin="00:52:54.333"
        end="00:52:56.458"><span region="Default">- Memang begitu?<br/>- Dasar goblok!</span></p>
      <p
        begin="00:52:57.458"
        end="00:52:59.875"><span region="Default">Jaman dulu waktu kita jadi kuli pangkul,</span></p>
      <p
        begin="00:52:59.958"
        end="00:53:02.708"><span region="Default">Juragan Bisman itu<br/>sudah jadi juragan kaya.</span></p>
      <p
        begin="00:53:02.791"
        end="00:53:06.458"><span region="Default">Kalau dia sekarang sudah engga suka<br/>sama kita, gampang saja dia depak kita.</span></p>
      <p
        begin="00:53:07.541"
        end="00:53:08.750"><span region="Default">Jadi…</span></p>
      <p
        begin="00:53:09.708"
        end="00:53:10.958"><span region="Default">kita harus bagaimana?</span></p>
      <p
        begin="00:53:11.791"
        end="00:53:14.083"><span region="Default">Sumber masalahnya itu Suzzanna.</span></p>
      <p
        begin="00:53:15.625"
        end="00:53:18.083"><span region="Default">Suzzanna sudah meracuni pikiran juragan.</span></p>
      <p
        begin="00:53:18.166"
        end="00:53:22.375"><span region="Default">Kalau racun itu mati,<br/>Juragan bakal sadar lagi.</span></p>
      <p
        begin="00:53:24.250"
        end="00:53:26.583"><span region="Default">Jadi Suzzanna harus kita bunuh duluan.</span></p>
      <p
        begin="00:53:27.375"
        end="00:53:29.458"><span region="Default">Sebelum juragan terlanjur menghabisi kita.</span></p>
      <p
        begin="00:53:30.666"
        end="00:53:33.416"><span region="Default">Kenapa kamu ikutan Lawu jadi orang bodoh?</span></p>
      <p
        begin="00:53:35.083"
        end="00:53:38.041"><span region="Default">Lebih baik bodoh tapi bertindak!</span></p>
      <p
        begin="00:53:38.125"
        end="00:53:40.291"><span region="Default">Daripada pintar tapi pengecut?</span></p>
      <p
        begin="00:53:41.333"
        end="00:53:45.166"><span region="Default">Kalau kalian engga berani,<br/>aku bisa jalan sendiri!</span></p>
      <p
        begin="00:54:42.500"
        end="00:54:45.041"><span region="Default">Hei? Eh, eh.</span></p>
      <p
        begin="00:54:46.750"
        end="00:54:47.833"><span region="Default">Heh!</span></p>
      <p
        begin="00:54:48.583"
        end="00:54:49.666"><span region="Default">Heh!</span></p>
      <p
        begin="00:55:48.208"
        end="00:55:49.708"><span region="Default">Hei, rampok!</span></p>
      <p
        begin="00:59:00.791"
        end="00:59:03.166"><span region="Default">Juragan.</span></p>
      <p
        begin="00:59:04.333"
        end="00:59:07.750"><span region="Default">Saya engga kuat.</span></p>
      <p
        begin="00:59:09.041"
        end="00:59:12.833"><span region="Default">Mending mati saja, Juragan.</span></p>
      <p
        begin="00:59:12.916"
        end="00:59:15.958"><span region="Default">Ngawur. Kamu harus kuat.</span></p>
      <p
        begin="00:59:16.583"
        end="00:59:18.916"><span region="Default">Demi Allah.</span></p>
      <p
        begin="00:59:20.083"
        end="00:59:21.875"><span region="Default">Engga kuat.</span></p>
      <p
        begin="00:59:22.875"
        end="00:59:26.833"><span region="Default">Tolong bunuh saya.</span></p>
      <p
        begin="00:59:28.791"
        end="00:59:30.000"><span region="Default">Tolong.</span></p>
      <p
        begin="00:59:31.041"
        end="00:59:33.875"><span region="Default">Bunuh saya, Juragan.</span></p>
      <p
        begin="00:59:35.125"
        end="00:59:38.000"><span region="Default">Bunuh saya, tolong.</span></p>
      <p
        begin="00:59:39.083"
        end="00:59:40.500"><span region="Default">Tolong.</span></p>
      <p
        begin="00:59:40.583"
        end="00:59:44.500"><span region="Default">Bunuh saya, Juragan.</span></p>
      <p
        begin="00:59:45.333"
        end="00:59:47.791"><span region="Default">Bunuh saya.</span></p>
      <p
        begin="00:59:47.875"
        end="00:59:49.208"><span region="Default">Tolong.</span></p>
      <p
        begin="00:59:49.291"
        end="00:59:51.166"><span region="Default">Maafkan semua kesalahan saya.</span></p>
      <p
        begin="00:59:51.250"
        end="00:59:52.666"><span region="Default">Bunuh…</span></p>
      <p
        begin="01:00:03.458"
        end="01:00:04.625"><span region="Default">Juragan!</span></p>
      <p
        begin="01:00:12.250"
        end="01:00:14.666"><span region="Default">Saya tahu apa<br/>yang ada dalam pikiran kalian.</span></p>
      <p
        begin="01:00:14.750"
        end="01:00:16.166"><span region="Default">Tapi demi Allah,</span></p>
      <p
        begin="01:00:17.208"
        end="01:00:19.958"><span region="Default">saya sama sekali<br/>tidak berniat membunuh Banteng.</span></p>
      <p
        begin="01:00:21.500"
        end="01:00:25.250"><span region="Default">Saya tidak tega<br/>dia berlama-lama menderita.</span></p>
      <p
        begin="01:00:27.541"
        end="01:00:30.333"><span region="Default">Jangan bawa-bawa nama Gusti Allah, Gan.</span></p>
      <p
        begin="01:00:31.708"
        end="01:00:34.666"><span region="Default">Gusti Allah juga gak akan peduli.</span></p>
      <p
        begin="01:00:35.250"
        end="01:00:37.666"><span region="Default">Namanya sampeyan sebut-sebut.</span></p>
      <p
        begin="01:00:39.541"
        end="01:00:41.291"><span region="Default">Kayak yang kenal agama saja.</span></p>
      <p
        begin="01:00:54.166"
        end="01:00:55.125"><span region="Default">Mas.</span></p>
      <p
        begin="01:00:56.500"
        end="01:00:57.666"><span region="Default">Malam.</span></p>
      <p
        begin="01:01:00.041"
        end="01:01:02.083"><span region="Default">Saya hanya mau mengantar makanan.</span></p>
      <p
        begin="01:01:03.625"
        end="01:01:07.833"><span region="Default">Saya tahu kamu sedang berduka.<br/>Tapi saya pikir mungkin kamu belum makan.</span></p>
      <p
        begin="01:01:09.875"
        end="01:01:12.333"><span region="Default">Terima kasih untuk makanannya, Mas.</span></p>
      <p
        begin="01:01:12.875"
        end="01:01:13.958"><span region="Default">Masuk dulu.</span></p>
      <p
        begin="01:01:16.375"
        end="01:01:17.750"><span region="Default">Bagaimana, Mas?</span></p>
      <p
        begin="01:01:18.458"
        end="01:01:20.208"><span region="Default">Sudah tahu bapakmu di mana?</span></p>
      <p
        begin="01:01:22.791"
        end="01:01:26.375"><span region="Default">Sepertinya Pak Lurah<br/>mengetahui sesuatu tentang bapakku.</span></p>
      <p
        begin="01:01:27.375"
        end="01:01:29.166"><span region="Default">Tapi ia masih menutupinya.</span></p>
      <p
        begin="01:01:30.458"
        end="01:01:32.083"><span region="Default">Jadi kapan kamu pulang?</span></p>
      <p
        begin="01:01:33.958"
        end="01:01:36.958"><span region="Default">Ya, sementara saya akan di sini dulu.</span></p>
      <p
        begin="01:01:37.791"
        end="01:01:40.500"><span region="Default">Sambil mencari tahu<br/>apa yang ditutupi oleh Bisman.</span></p>
      <p
        begin="01:01:42.833"
        end="01:01:44.875"><span region="Default">Kamu jangan dekat-dekat dengan Bisman.</span></p>
      <p
        begin="01:01:45.916"
        end="01:01:47.250"><span region="Default">Dia berbahaya.</span></p>
      <p
        begin="01:01:49.541"
        end="01:01:50.750"><span region="Default">Dia yang bunuh Bapak.</span></p>
      <p
        begin="01:01:57.208"
        end="01:01:58.750"><span region="Default">Aku hanya akan…</span></p>
      <p
        begin="01:02:01.041"
        end="01:02:03.125"><span region="Default">membongkar kebusukannya dan membantumu.</span></p>
      <p
        begin="01:02:03.708"
        end="01:02:05.375"><span region="Default">Saya tidak perlu dibantu.</span></p>
      <p
        begin="01:02:08.083"
        end="01:02:11.250"><span region="Default">Saya tidak ingin terjadi apa-apa denganmu.<br/>Saya tidak mau…</span></p>
      <p
        begin="01:02:14.541"
        end="01:02:17.541"><span region="Default">Saya tidak ingin kehilangan orang<br/>yang sudah baik padaku.</span></p>
      <p
        begin="01:02:19.125"
        end="01:02:20.500"><span region="Default">Jangan takut.</span></p>
      <p
        begin="01:02:21.250"
        end="01:02:24.125"><span region="Default">Aku sudah tidak punya rasa takut lagi.</span></p>
      <p
        begin="01:02:29.000"
        end="01:02:30.875"><span region="Default">Kamu jangan lama-lama di sini.</span></p>
      <p
        begin="01:02:30.958"
        end="01:02:32.500"><span region="Default">Kamu tidak aman.</span></p>
      <p
        begin="01:02:33.333"
        end="01:02:35.125"><span region="Default">Mereka membunuh keluargamu.</span></p>
      <p
        begin="01:02:35.208"
        end="01:02:38.125"><span region="Default">Aku akan membalas dendamku<br/>kepada mereka semua, Mas.</span></p>
      <p
        begin="01:02:38.208"
        end="01:02:40.125"><span region="Default">Dengan cara apa?</span></p>
      <p
        begin="01:02:41.208"
        end="01:02:43.208"><span region="Default">Kamu ini sendirian, Suzzanna.</span></p>
      <p
        begin="01:02:43.291"
        end="01:02:45.375"><span region="Default">Bisa-bisa kamu yang jadi korban.</span></p>
      <p
        begin="01:02:46.291"
        end="01:02:49.000"><span region="Default">Penindasan menuntut pemberontakan.</span></p>
      <p
        begin="01:02:50.416"
        end="01:02:53.500"><span region="Default">Kalau di situ aku yang<br/>akan jadi korbannya, biarlah.</span></p>
      <p
        begin="01:02:53.583"
        end="01:02:55.833"><span region="Default">- Suzzanna, kamu…<br/>- Sudah malam, Mas.</span></p>
      <p
        begin="01:03:04.166"
        end="01:03:06.625"><span region="Default">Aku… Aku permisi.</span></p>
      <p
        begin="01:03:14.833"
        end="01:03:16.500"><span region="Default">Jangan lupa makan.</span></p>
      <p
        begin="01:03:20.958"
        end="01:03:23.333"><span region="Default">Kemarin ada guru ngaji datang ke sini.</span></p>
      <p
        begin="01:03:23.416"
        end="01:03:26.666"><span region="Default">Katanya kamu yang nyuruh dia<br/>buat ngajari aku ngaji.</span></p>
      <p
        begin="01:03:26.750"
        end="01:03:28.583"><span region="Default">Bener, apa ngejek aku?</span></p>
      <p
        begin="01:03:28.666"
        end="01:03:31.708"><span region="Default">Guru ngaji? Siapa namanya?</span></p>
      <p
        begin="01:03:31.791"
        end="01:03:33.791"><span region="Default">Lastri apa siapa gitu?</span></p>
      <p
        begin="01:03:34.375"
        end="01:03:35.791"><span region="Default">Perempuan?</span></p>
      <p
        begin="01:03:36.916"
        end="01:03:39.041"><span region="Default">- Orang mana?<br/>- Dari Karang Setan katanya.</span></p>
      <p
        begin="01:03:43.500"
        end="01:03:44.583"><span region="Default">Seperti apa orangnya?</span></p>
      <p
        begin="01:03:45.250"
        end="01:03:47.166"><span region="Default">Kok nanyanya mendalam banget?</span></p>
      <p
        begin="01:03:47.791"
        end="01:03:49.750"><span region="Default">- Pacarmu, ya?<br/>- Sembarangan.</span></p>
      <p
        begin="01:03:49.833"
        end="01:03:51.666"><span region="Default">Mengaku saja.</span></p>
      <p
        begin="01:03:51.750"
        end="01:03:55.500"><span region="Default">Kalau engga ada hubungan apa-apa,<br/>buat apa dia minta fotomu?</span></p>
      <p
        begin="01:03:56.125"
        end="01:03:57.166"><span region="Default">Minta foto?</span></p>
      <p
        begin="01:03:57.750"
        end="01:03:59.208"><span region="Default">Terus kamu kasih?</span></p>
      <p
        begin="01:04:22.750"
        end="01:04:26.125"><span region="Default">Sore-sore kok ngelamun.</span></p>
      <p
        begin="01:04:26.208"
        end="01:04:27.958"><span region="Default">Nanti kesambet, lo.</span></p>
      <p
        begin="01:04:44.208"
        end="01:04:48.291"><span region="Default">Anak-anakku yang aku cintai.</span></p>
      <p
        begin="01:04:49.416"
        end="01:04:53.000"><span region="Default">Kemarilah.</span></p>
      <p
        begin="01:04:57.500"
        end="01:05:02.666"><span region="Default">Perintahkan orang itu<br/>untuk memanjat pohon kelapa.</span></p>
      <p
        begin="01:05:48.041"
        end="01:05:51.666"><span region="Default">Mas? Siapa yang minta kelapa, Mas?</span></p>
      <p
        begin="01:06:28.916"
        end="01:06:31.541"><span region="Default">Ya ampun, Mas!</span></p>
      <p
        begin="01:06:34.041"
        end="01:06:35.208"><span region="Default">Mas!</span></p>
      <p
        begin="01:06:35.291"
        end="01:06:37.250"><span region="Default">Mas Lawu!</span></p>
      <p
        begin="01:06:39.833"
        end="01:06:41.166"><span region="Default">Tolong!</span></p>
      <p
        begin="01:06:59.291"
        end="01:07:00.625"><span region="Default">Juragan.</span></p>
      <p
        begin="01:07:17.000"
        end="01:07:18.166"><span region="Default">Ternyata</span></p>
      <p
        begin="01:07:18.916"
        end="01:07:20.791"><span region="Default">demi seorang perempuan,</span></p>
      <p
        begin="01:07:21.708"
        end="01:07:25.250"><span region="Default">Juragan gampang sekali<br/>mengorbankan anak buahnya sendiri.</span></p>
      <p
        begin="01:07:27.250"
        end="01:07:28.958"><span region="Default">Minggu lalu Banteng mati.</span></p>
      <p
        begin="01:07:29.750"
        end="01:07:30.833"><span region="Default">Sekarang, Lawu.</span></p>
      <p
        begin="01:07:32.708"
        end="01:07:35.541"><span region="Default">Saya memang marah sekali sama kalian.</span></p>
      <p
        begin="01:07:37.250"
        end="01:07:40.958"><span region="Default">Tapi saya tidak mungkin tega<br/>anak buah sendiri saya kirim santet.</span></p>
      <p
        begin="01:07:45.125"
        end="01:07:46.250"><span region="Default">Hei!</span></p>
      <p
        begin="01:07:47.916"
        end="01:07:49.500"><span region="Default">Mau ke mana kamu?</span></p>
      <p
        begin="01:07:49.583"
        end="01:07:51.375"><span region="Default">Ayo!</span></p>
      <p
        begin="01:07:57.041"
        end="01:07:58.416"><span region="Default">Keluar!</span></p>
      <p
        begin="01:07:59.208"
        end="01:08:00.166"><span region="Default">Lesus!</span></p>
      <p
        begin="01:08:00.791"
        end="01:08:02.041"><span region="Default">Keluar kamu!</span></p>
      <p
        begin="01:08:02.125"
        end="01:08:03.458"><span region="Default">Keluar kamu!</span></p>
      <p
        begin="01:08:04.208"
        end="01:08:05.833"><span region="Default">Serang! Bakar!</span></p>
      <p
        begin="01:08:09.583"
        end="01:08:11.291"><span region="Default">Bakar dia!</span></p>
      <p
        begin="01:08:11.375"
        end="01:08:12.916"><span region="Default">Ayo semuanya!</span></p>
      <p
        begin="01:08:19.208"
        end="01:08:21.708"><span region="Default">Pasti dia punya ajian kebal.</span></p>
      <p
        begin="01:08:21.791"
        end="01:08:23.333"><span region="Default">Maksudmu?</span></p>
      <p
        begin="01:08:23.958"
        end="01:08:25.458"><span region="Default">Coba potong jempol kakinya.</span></p>
      <p
        begin="01:08:26.791"
        end="01:08:28.916"><span region="Default">Biasanya kelemahannya di situ.</span></p>
      <p
        begin="01:08:29.500"
        end="01:08:30.875"><span region="Default">Tangkap. Tangkap dia.</span></p>
      <p
        begin="01:08:30.958"
        end="01:08:33.416"><span region="Default">- Ayo.<br/>- Hei!</span></p>
      <p
        begin="01:08:33.500"
        end="01:08:34.666"><span region="Default">Pegang!</span></p>
      <p
        begin="01:08:34.750"
        end="01:08:36.333"><span region="Default">Bawah, ayo.</span></p>
      <p
        begin="01:08:37.250"
        end="01:08:38.541"><span region="Default">Tusuk.</span></p>
      <p
        begin="01:08:40.708"
        end="01:08:41.958"><span region="Default">Tusuk, tusuk.</span></p>
      <p
        begin="01:08:57.125"
        end="01:08:58.666"><span region="Default">Bakar dia.</span></p>
      <p
        begin="01:09:05.916"
        end="01:09:08.750"><span region="Default">Abisin, lempar semuanya!</span></p>
      <p
        begin="01:09:24.041"
        end="01:09:25.416"><span region="Default">Bakar dia!</span></p>
      <p
        begin="01:09:26.583"
        end="01:09:29.583"><span region="Default">- Ayo pulang!<br/>- Ayo!</span></p>
      <p
        begin="01:10:07.416"
        end="01:10:08.583"><span region="Default">Juragan?</span></p>
      <p
        begin="01:10:28.791"
        end="01:10:30.458"><span region="Default">Ada apa, Wi?</span></p>
      <p
        begin="01:10:30.541"
        end="01:10:31.750"><span region="Default">Tenang, Juragan.</span></p>
      <p
        begin="01:10:32.416"
        end="01:10:34.166"><span region="Default">Saya engga akan macam-macam.</span></p>
      <p
        begin="01:10:34.791"
        end="01:10:37.041"><span region="Default">Saya sudah lega</span></p>
      <p
        begin="01:10:37.125"
        end="01:10:40.125"><span region="Default">karena Juragan engga mungkin lagi<br/>nyantet saya dan Lawu.</span></p>
      <p
        begin="01:10:40.208"
        end="01:10:43.291"><span region="Default">Dukun santet langganan Juragan,</span></p>
      <p
        begin="01:10:43.375"
        end="01:10:45.041"><span region="Default">sudah jadi mayat.</span></p>
      <p
        begin="01:10:47.250"
        end="01:10:49.250"><span region="Default">Dasar turunan setan yang paling goblok!</span></p>
      <p
        begin="01:10:50.166"
        end="01:10:51.416"><span region="Default">Buat apa bunuh dia?</span></p>
      <p
        begin="01:10:51.500"
        end="01:10:53.833"><span region="Default">Sudah berkali-kali saya katakan,</span></p>
      <p
        begin="01:10:53.916"
        end="01:10:57.041"><span region="Default">saya tidak pernah menyuruh siapa pun<br/>untuk menghabisi kalian!</span></p>
      <p
        begin="01:10:58.583"
        end="01:11:01.666"><span region="Default">Saya ini bingung, Wi!<br/>Sekarang tambah bingung lagi!</span></p>
      <p
        begin="01:11:12.333"
        end="01:11:13.541"><span region="Default">Mas?</span></p>
      <p
        begin="01:11:13.625"
        end="01:11:15.125"><span region="Default">Mas?</span></p>
      <p
        begin="01:11:15.208"
        end="01:11:16.208"><span region="Default">Lawu!</span></p>
      <p
        begin="01:11:16.875"
        end="01:11:17.916"><span region="Default">Wu. Lawu!</span></p>
      <p
        begin="01:11:18.833"
        end="01:11:19.833"><span region="Default">Lawu?</span></p>
      <p
        begin="01:11:26.541"
        end="01:11:27.500"><span region="Default">Suster!</span></p>
      <p
        begin="01:11:34.708"
        end="01:11:36.416"><span region="Default">Wu. Lawu!</span></p>
      <p
        begin="01:12:25.416"
        end="01:12:30.125"><span region="Default">Lihat! Kamu pikir Lesus<br/>yang sudah mati masih bisa kirim santet?</span></p>
      <p
        begin="01:12:31.125"
        end="01:12:32.333"><span region="Default">Mas Lawu!</span></p>
      <p
        begin="01:12:33.083"
        end="01:12:34.416"><span region="Default">Mas? Mas!</span></p>
      <p
        begin="01:12:34.500"
        end="01:12:37.458"><span region="Default">Mas Lawu!</span></p>
      <p
        begin="01:12:41.416"
        end="01:12:42.750"><span region="Default">Assalamualaikum.</span></p>
      <p
        begin="01:12:42.833"
        end="01:12:45.291"><span region="Default">Waalaikumsalam. Mau ketemu siapa, Mas?</span></p>
      <p
        begin="01:12:45.375"
        end="01:12:47.791"><span region="Default">Saya mau bertemu dengan Pak Lurah.</span></p>
      <p
        begin="01:12:48.833"
        end="01:12:50.416"><span region="Default">Sebentar, ya.</span></p>
      <p
        begin="01:12:50.500"
        end="01:12:52.000"><span region="Default">Duduk dulu aja.</span></p>
      <p
        begin="01:12:52.083"
        end="01:12:53.458"><span region="Default">Terima kasih.</span></p>
      <p
        begin="01:12:54.916"
        end="01:12:56.166"><span region="Default">Jadi…</span></p>
      <p
        begin="01:12:56.250"
        end="01:12:59.041"><span region="Default">Siapa sebenarnya yang ngirim santet<br/>ke Banteng dan Lawu?</span></p>
      <p
        begin="01:12:59.875"
        end="01:13:01.416"><span region="Default">Maaf, Juragan.</span></p>
      <p
        begin="01:13:01.500"
        end="01:13:04.958"><span region="Default">Saya tidak bisa menduga siapa pelakunya.</span></p>
      <p
        begin="01:13:05.708"
        end="01:13:08.583"><span region="Default">Tapi, siapa pun dia,</span></p>
      <p
        begin="01:13:08.666"
        end="01:13:12.750"><span region="Default">menurut saya, dia bertindak<br/>atas permintaan Suzzanna.</span></p>
      <p
        begin="01:13:13.500"
        end="01:13:16.166"><span region="Default">Kenapa kamu berpikir begitu?</span></p>
      <p
        begin="01:13:16.750"
        end="01:13:20.916"><span region="Default">Memangnya, ada orang lain yang punya<br/>dendam sama kita melebihi Suzzanna?</span></p>
      <p
        begin="01:13:23.958"
        end="01:13:27.041"><span region="Default">Kliwon! Tohir! Diran!</span></p>
      <p
        begin="01:13:27.125"
        end="01:13:28.416"><span region="Default">- Iya!<br/>- Ya, Juragan!</span></p>
      <p
        begin="01:13:28.500"
        end="01:13:29.708"><span region="Default">Ya, Juragan?</span></p>
      <p
        begin="01:13:32.666"
        end="01:13:34.875"><span region="Default">Aku perintahkan kalian bertiga</span></p>
      <p
        begin="01:13:34.958"
        end="01:13:37.916"><span region="Default">mulai hari ini<br/>awasi Suzzanna 24 jam sehari.</span></p>
      <p
        begin="01:13:38.000"
        end="01:13:42.416"><span region="Default">Kalau kedapatan dia menerima tamu,<br/>atau ada orang yang mencurigakan</span></p>
      <p
        begin="01:13:42.500"
        end="01:13:43.625"><span region="Default">cepat lapor ke aku.</span></p>
      <p
        begin="01:13:44.333"
        end="01:13:46.125"><span region="Default">Bisa jadi dia dukun santetnya.</span></p>
      <p
        begin="01:13:47.375"
        end="01:13:49.208"><span region="Default">Atau anak buahnya yang disewa Suzzanna.</span></p>
      <p
        begin="01:13:49.291"
        end="01:13:51.041"><span region="Default">- Paham?<br/>- Paham, Juragan.</span></p>
      <p
        begin="01:13:51.125"
        end="01:13:54.875"><span region="Default">Kalau kalian bisa<br/>menangkap siapa dukun santetnya,</span></p>
      <p
        begin="01:13:54.958"
        end="01:13:57.166"><span region="Default">gaji kalian saya naikkan tiga kali lipat.</span></p>
      <p
        begin="01:13:57.833"
        end="01:13:59.625"><span region="Default">Jadi, buka mata kalian.</span></p>
      <p
        begin="01:14:04.166"
        end="01:14:06.000"><span region="Default">Hei, kamu!</span></p>
      <p
        begin="01:14:10.625"
        end="01:14:12.166"><span region="Default">Lagi apa kamu di situ?</span></p>
      <p
        begin="01:14:12.833"
        end="01:14:14.458"><span region="Default">Saya…</span></p>
      <p
        begin="01:14:14.541"
        end="01:14:18.250"><span region="Default">ingin bertanya tentang informasi<br/>bapak saya. Apa Pak Lurah ada waktu?</span></p>
      <p
        begin="01:14:18.333"
        end="01:14:20.791"><span region="Default">- Siapa namamu?<br/>- Pramuja.</span></p>
      <p
        begin="01:14:20.875"
        end="01:14:22.500"><span region="Default">Sudah saya katakan,</span></p>
      <p
        begin="01:14:22.583"
        end="01:14:24.041"><span region="Default">bapakmu sudah mati.</span></p>
      <p
        begin="01:14:25.458"
        end="01:14:27.500"><span region="Default">Jadi, maaf.</span></p>
      <p
        begin="01:14:27.583"
        end="01:14:29.416"><span region="Default">Tidak ada yang bisa saya bantu lagi.</span></p>
      <p
        begin="01:14:33.708"
        end="01:14:35.916"><span region="Default">Ingat ya, buka mata kalian.</span></p>
      <p
        begin="01:14:36.000"
        end="01:14:38.750"><span region="Default">Kita harus cari tahu<br/>siapa dukun santetnya.</span></p>
      <p
        begin="01:14:39.583"
        end="01:14:43.750"><span region="Default">Demi gaji tiga kali lipat,<br/>ketemu setan juga berani, dah.</span></p>
      <p
        begin="01:14:45.333"
        end="01:14:46.916"><span region="Default">Ini 'kan dukun santet, Hir?</span></p>
      <p
        begin="01:14:47.000"
        end="01:14:48.083"><span region="Default">Maksud lu?</span></p>
      <p
        begin="01:14:48.166"
        end="01:14:50.666"><span region="Default">Lah kalau setan, kita bisa kabur</span></p>
      <p
        begin="01:14:50.750"
        end="01:14:53.541"><span region="Default">lah kalau dukun santet,<br/>lu mau kabur ke mana juga bakal disantet.</span></p>
      <p
        begin="01:14:55.416"
        end="01:14:56.750"><span region="Default">Bener juga, ya.</span></p>
      <p
        begin="01:14:57.916"
        end="01:14:59.041"><span region="Default">Aduh.</span></p>
      <p
        begin="01:15:01.000"
        end="01:15:02.791"><span region="Default">Gue jadi takut.</span></p>
      <p
        begin="01:15:03.750"
        end="01:15:04.625"><span region="Default">Aduh.</span></p>
      <p
        begin="01:15:04.708"
        end="01:15:08.083"><span region="Default">Lagian gimana caranya kita bisa tahu</span></p>
      <p
        begin="01:15:08.166"
        end="01:15:09.666"><span region="Default">seseorang itu dukun santet?</span></p>
      <p
        begin="01:15:09.750"
        end="01:15:11.666"><span region="Default">Kata nenek gue,</span></p>
      <p
        begin="01:15:11.750"
        end="01:15:16.291"><span region="Default">dukun santet itu biasanya<br/>piara keris sama boneka santet.</span></p>
      <p
        begin="01:15:17.250"
        end="01:15:21.125"><span region="Default">Siapa yang punya barang itu,<br/>itu dia dukun santetnya.</span></p>
      <p
        begin="01:15:22.625"
        end="01:15:23.916"><span region="Default">Gue jadi makin takut.</span></p>
      <p
        begin="01:15:24.708"
        end="01:15:27.000"><span region="Default">- Gue juga.<br/>- Apa?</span></p>
      <p
        begin="01:15:27.750"
        end="01:15:29.000"><span region="Default">Tohir, sini.</span></p>
      <p
        begin="01:15:31.416"
        end="01:15:33.666"><span region="Default">Lu sama gue, ngecek ke sono, ya?</span></p>
      <p
        begin="01:15:34.333"
        end="01:15:36.125"><span region="Default">Diran, lu ngecek ke sono.</span></p>
      <p
        begin="01:15:36.208"
        end="01:15:37.791"><span region="Default">Apa?</span></p>
      <p
        begin="01:15:37.875"
        end="01:15:39.166"><span region="Default">Kok gue sendirian?</span></p>
      <p
        begin="01:15:39.250"
        end="01:15:42.500"><span region="Default">- Udah, engga usah takut kayak begitu.<br/>- Ayo, Hir.</span></p>
      <p
        begin="01:15:44.041"
        end="01:15:45.791"><span region="Default">Tohir? Kliwon?</span></p>
      <p
        begin="01:15:47.416"
        end="01:15:48.458"><span region="Default">Aduuuh.</span></p>
      <p
        begin="01:15:54.916"
        end="01:15:56.500"><span region="Default">Suzzanna.</span></p>
      <p
        begin="01:15:56.583"
        end="01:15:59.250"><span region="Default">- Kok kamu masih di sini, Mas?<br/>- Aku perlu memberitahumu sesuatu.</span></p>
      <p
        begin="01:16:13.250"
        end="01:16:14.833"><span region="Default">Aku tadi bertemu dengan Bisman.</span></p>
      <p
        begin="01:16:14.916"
        end="01:16:18.833"><span region="Default">dan aku mendengar anak buahnya<br/>mengira bahwa kamu menyewa dukun santet</span></p>
      <p
        begin="01:16:18.916"
        end="01:16:20.125"><span region="Default">untuk menyantet mereka.</span></p>
      <p
        begin="01:16:21.833"
        end="01:16:24.416"><span region="Default">Sekarang mereka sudah mengirim orang<br/>untuk memata-mataimu.</span></p>
      <p
        begin="01:16:24.500"
        end="01:16:25.791"><span region="Default">Kita harus segera pergi dari sini.</span></p>
      <p
        begin="01:16:27.291"
        end="01:16:28.791"><span region="Default">Kamu tidak aman sendiri.</span></p>
      <p
        begin="01:16:29.833"
        end="01:16:31.500"><span region="Default">Aku tidak bisa pergi, Mas.</span></p>
      <p
        begin="01:16:31.583"
        end="01:16:33.458"><span region="Default">Kamu berpikir apa, Suzzanna?</span></p>
      <p
        begin="01:16:34.875"
        end="01:16:36.666"><span region="Default">Kamu tidak bisa melawan mereka sendirian.</span></p>
      <p
        begin="01:16:37.208"
        end="01:16:40.041"><span region="Default">Mereka sudah terlalu gila,<br/>berpikir bahwa kamu menyantet mereka.</span></p>
      <p
        begin="01:16:40.833"
        end="01:16:42.708"><span region="Default">Kamu tidak mengerti, Mas.</span></p>
      <p
        begin="01:16:46.041"
        end="01:16:47.291"><span region="Default">Lebih baik kamu pergi.</span></p>
      <p
        begin="01:16:48.458"
        end="01:16:50.625"><span region="Default">Nanti kita ketemu lagi<br/>setelah semua selesai.</span></p>
      <p
        begin="01:16:50.708"
        end="01:16:52.583"><span region="Default">Aku tidak mengerti cara berpikirmu.</span></p>
      <p
        begin="01:16:57.125"
        end="01:16:58.416"><span region="Default">Burung gagak?</span></p>
      <p
        begin="01:17:37.458"
        end="01:17:40.500"><span region="Default">Kenapa harus hal seperti ini<br/>yang kau pelajari dari Bude Gayatri?</span></p>
      <p
        begin="01:17:40.583"
        end="01:17:42.208"><span region="Default">Ini satu-satunya cara.</span></p>
      <p
        begin="01:17:42.291"
        end="01:17:44.166"><span region="Default">Satu-satunya cara bagi siapa?</span></p>
      <p
        begin="01:17:46.083"
        end="01:17:48.250"><span region="Default">Bagi orang-orang<br/>yang tidak percaya pada kekuatan Allah?</span></p>
      <p
        begin="01:17:49.208"
        end="01:17:51.083"><span region="Default">Kau bukan orang<br/>yang seperti itu, Suzzanna.</span></p>
      <p
        begin="01:17:51.166"
        end="01:17:53.833"><span region="Default">Tidak semua orang<br/>bernasib buruk sepertiku.</span></p>
      <p
        begin="01:17:53.916"
        end="01:17:58.083"><span region="Default">Tidak semua orang yang bernasib buruk<br/>melakukan jalan seperti ini.</span></p>
      <p
        begin="01:18:01.291"
        end="01:18:04.000"><span region="Default">Jalan macam apa<br/>yang menurutmu aku pantas tempuh?</span></p>
      <p
        begin="01:18:06.375"
        end="01:18:07.833"><span region="Default">Berdoa?</span></p>
      <p
        begin="01:18:08.375"
        end="01:18:10.833"><span region="Default">Dan terus berdoa<br/>memohon perlindungan Allah?</span></p>
      <p
        begin="01:18:10.916"
        end="01:18:11.875"><span region="Default">Suzzanna.</span></p>
      <p
        begin="01:18:13.833"
        end="01:18:16.958"><span region="Default">Bertahun-tahun aku menyembahNya<br/>dengan sepenuh hati.</span></p>
      <p
        begin="01:18:17.708"
        end="01:18:19.125"><span region="Default">Yakin bahwa Ia ada.</span></p>
      <p
        begin="01:18:22.208"
        end="01:18:25.541"><span region="Default">Yakin dengan kekuatan dan kekuasaanNya.</span></p>
      <p
        begin="01:18:25.625"
        end="01:18:27.583"><span region="Default">Bahwa Dia akan selalu melindungiku.</span></p>
      <p
        begin="01:18:28.875"
        end="01:18:31.500"><span region="Default">Melindungi orang-orang yang aku cintai.</span></p>
      <p
        begin="01:18:34.916"
        end="01:18:36.166"><span region="Default">Bapak.</span></p>
      <p
        begin="01:18:37.375"
        end="01:18:38.500"><span region="Default">Ibu.</span></p>
      <p
        begin="01:18:41.416"
        end="01:18:42.750"><span region="Default">Tapi apa yang terjadi?</span></p>
      <p
        begin="01:18:44.458"
        end="01:18:47.708"><span region="Default">Di saat datang<br/>orang-orang jahat yang menyantet Bapak,</span></p>
      <p
        begin="01:18:48.541"
        end="01:18:50.000"><span region="Default">menzolimi Ibu…</span></p>
      <p
        begin="01:18:52.375"
        end="01:18:54.166"><span region="Default">Apa ada datang pertolongan?</span></p>
      <p
        begin="01:18:54.875"
        end="01:18:56.333"><span region="Default">Tidak ada.</span></p>
      <p
        begin="01:18:59.750"
        end="01:19:02.208"><span region="Default">- Suzzanna, kamu…<br/>- Mbak Suzzanna?</span></p>
      <p
        begin="01:19:09.958"
        end="01:19:11.083"><span region="Default">Ada apa, Mas?</span></p>
      <p
        begin="01:19:12.916"
        end="01:19:15.875"><span region="Default">Barusan, saya dengar ada suara laki-laki.</span></p>
      <p
        begin="01:19:16.875"
        end="01:19:18.333"><span region="Default">Apa ada orang lain di sini?</span></p>
      <p
        begin="01:19:19.625"
        end="01:19:21.125"><span region="Default">Tidak ada siapa-siapa, Mas.</span></p>
      <p
        begin="01:19:24.000"
        end="01:19:26.750"><span region="Default">Kalau mau, silakan lihat sendiri.</span></p>
      <p
        begin="01:19:27.416"
        end="01:19:28.541"><span region="Default">Iya.</span></p>
      <p
        begin="01:19:29.125"
        end="01:19:30.416"><span region="Default">Permisi.</span></p>
      <p
        begin="01:20:13.458"
        end="01:20:14.291"><span region="Default">Hah?</span></p>
      <p
        begin="01:20:20.416"
        end="01:20:21.875"><span region="Default">Ada apa, Mas?</span></p>
      <p
        begin="01:20:22.916"
        end="01:20:25.875"><span region="Default">Benar kata Mbak. Engga ada siapa-siapa.</span></p>
      <p
        begin="01:20:28.666"
        end="01:20:30.708"><span region="Default">Duduk, saya buatkan minuman.</span></p>
      <p
        begin="01:20:30.791"
        end="01:20:32.958"><span region="Default">Makasih, saya udah kenyang.</span></p>
      <p
        begin="01:20:34.125"
        end="01:20:35.291"><span region="Default">Aduh.</span></p>
      <p
        begin="01:20:47.875"
        end="01:20:48.916"><span region="Default">Kliwon!</span></p>
      <p
        begin="01:20:50.208"
        end="01:20:52.083"><span region="Default">Hir, maaf, Hir! Maaf.</span></p>
      <p
        begin="01:20:54.375"
        end="01:20:56.791"><span region="Default">Kliwon? Tohir!</span></p>
      <p
        begin="01:20:57.958"
        end="01:20:59.791"><span region="Default">Bahaya!</span></p>
      <p
        begin="01:20:59.875"
        end="01:21:01.708"><span region="Default">Hantu!</span></p>
      <p
        begin="01:21:01.791"
        end="01:21:03.833"><span region="Default">- Hantu…<br/>- Ini si Tohir, bukan hantu!</span></p>
      <p
        begin="01:21:04.583"
        end="01:21:06.333"><span region="Default">Sekarang gue tahu, siapa dukun santetnya.</span></p>
      <p
        begin="01:21:06.416"
        end="01:21:07.250"><span region="Default">- Siape?<br/>- Siapa?</span></p>
      <p
        begin="01:21:07.333"
        end="01:21:09.916"><span region="Default">Udah, kita langsung<br/>lapor aja sama Juragan, yuk?</span></p>
      <p
        begin="01:21:10.000"
        end="01:21:12.208"><span region="Default">Diran, tunggu!</span></p>
      <p
        begin="01:21:12.291"
        end="01:21:14.166"><span region="Default">Emang lu aja yang mau naik gaji? Woi!</span></p>
      <p
        begin="01:21:15.875"
        end="01:21:17.333"><span region="Default">Dia pasti tahu.</span></p>
      <p
        begin="01:21:18.333"
        end="01:21:20.791"><span region="Default">Dia akan segera melapor pada Bisman.</span></p>
      <p
        begin="01:21:21.458"
        end="01:21:23.125"><span region="Default">Kamu tenang saja, Mas.</span></p>
      <p
        begin="01:21:24.041"
        end="01:21:26.625"><span region="Default">Dia tidak akan bisa beritahu siapa-siapa.</span></p>
      <p
        begin="01:21:49.541"
        end="01:21:51.541"><span region="Default">Aku tidak sebaik yang kau kira.</span></p>
      <p
        begin="01:21:53.208"
        end="01:21:54.333"><span region="Default">Lebih baik kau pergi.</span></p>
      <p
        begin="01:22:01.541"
        end="01:22:02.625"><span region="Default">Pergi, Mas.</span></p>
      <p
        begin="01:22:41.416"
        end="01:22:43.291"><span region="Default">Saya tidak ada urusan sama kalian.</span></p>
      <p
        begin="01:23:07.375"
        end="01:23:09.708"><span region="Default">Sedang apa kamu di rumah Suzzanna?</span></p>
      <p
        begin="01:23:11.791"
        end="01:23:14.291"><span region="Default">Melindungi dia dari orang seperti kamu.</span></p>
      <p
        begin="01:23:16.375"
        end="01:23:18.125"><span region="Default">Mau melindungi siapa?</span></p>
      <p
        begin="01:23:18.875"
        end="01:23:21.916"><span region="Default">Melindungi dirimu<br/>sendiri saja kamu tidak bisa.</span></p>
      <p
        begin="01:23:23.083"
        end="01:23:25.333"><span region="Default">Saya yang berkuasa di sini.</span></p>
      <p
        begin="01:23:26.125"
        end="01:23:28.958"><span region="Default">Dan semua yang<br/>melawan saya akan saya habisi.</span></p>
      <p
        begin="01:23:31.083"
        end="01:23:34.458"><span region="Default">Saya tidak takut sama orang seperti kamu.</span></p>
      <p
        begin="01:24:35.666"
        end="01:24:37.000"><span region="Default">Kenapa kamu?</span></p>
      <p
        begin="01:24:37.083"
        end="01:24:38.958"><span region="Default">Didorong sama Kliwon, Juragan.</span></p>
      <p
        begin="01:24:39.041"
        end="01:24:40.291"><span region="Default">Kalian mau apa ke sini?</span></p>
      <p
        begin="01:24:40.916"
        end="01:24:43.125"><span region="Default">Bukannya ngawasi rumah Suzzanna?</span></p>
      <p
        begin="01:24:44.666"
        end="01:24:46.500"><span region="Default">Saya ada berita penting, Juragan.</span></p>
      <p
        begin="01:24:46.583"
        end="01:24:48.958"><span region="Default">- Pasti Juragan engga percaya.<br/>- Berita apa?</span></p>
      <p
        begin="01:24:49.041"
        end="01:24:51.458"><span region="Default">Saya tahu siapa dukun santetnya.</span></p>
      <p
        begin="01:24:53.958"
        end="01:24:55.000"><span region="Default">Siapa?</span></p>
      <p
        begin="01:24:55.083"
        end="01:24:56.625"><span region="Default">Dukun santetnya…</span></p>
      <p
        begin="01:24:59.041"
        end="01:25:00.250"><span region="Default">Jangan main-main sama aku!</span></p>
      <p
        begin="01:25:01.250"
        end="01:25:02.500"><span region="Default">Cepat katakan siapa!</span></p>
      <p
        begin="01:25:02.583"
        end="01:25:05.208"><span region="Default">Anu Juragan, dukun santetnya…</span></p>
      <p
        begin="01:25:05.916"
        end="01:25:07.625"><span region="Default">Kamu ini bisa bicara apa tidak?</span></p>
      <p
        begin="01:25:07.708"
        end="01:25:09.125"><span region="Default">Bisa, Juragan.</span></p>
      <p
        begin="01:25:09.208"
        end="01:25:10.875"><span region="Default">Dukun santetnya…</span></p>
      <p
        begin="01:25:13.000"
        end="01:25:15.250"><span region="Default">Kalian berdua, kalian 'kan tadi sama dia?</span></p>
      <p
        begin="01:25:15.333"
        end="01:25:16.541"><span region="Default">Iya, Juragan.</span></p>
      <p
        begin="01:25:16.625"
        end="01:25:18.166"><span region="Default">Jadi siapa dukun santetnya?</span></p>
      <p
        begin="01:25:18.250"
        end="01:25:20.583"><span region="Default">- Saya engga tahu, Juragan.<br/>- Saya juga engga tahu.</span></p>
      <p
        begin="01:25:20.666"
        end="01:25:23.125"><span region="Default">Kalian lihat ada orang masuk<br/>ke rumah Suzzanna tidak?</span></p>
      <p
        begin="01:25:23.208"
        end="01:25:24.916"><span region="Default">- Engga.<br/>- Engga, Juragan.</span></p>
      <p
        begin="01:25:25.000"
        end="01:25:27.333"><span region="Default">Yang satu gagap,<br/>yang dua tidak tahu apa-apa.</span></p>
      <p
        begin="01:25:27.416"
        end="01:25:30.291"><span region="Default">Percuma saya ngomong<br/>dengan orang bodoh seperti kalian.</span></p>
      <p
        begin="01:25:34.708"
        end="01:25:36.083"><span region="Default">Heh!</span></p>
      <p
        begin="01:25:36.166"
        end="01:25:37.958"><span region="Default">Lu mau kita dibunuh sama Juragan?</span></p>
      <p
        begin="01:25:38.041"
        end="01:25:40.208"><span region="Default">Apa? Kita bisa dibunuh?</span></p>
      <p
        begin="01:25:40.291"
        end="01:25:42.375"><span region="Default">Ya bisa aja kalo caranya kayak begini.</span></p>
      <p
        begin="01:25:42.458"
        end="01:25:46.125"><span region="Default">Lagian lu lapor sama Bos<br/>engga tau dukun santetnya siape.</span></p>
      <p
        begin="01:25:46.833"
        end="01:25:49.375"><span region="Default">Karena gue tau, gue liat.</span></p>
      <p
        begin="01:25:50.333"
        end="01:25:54.416"><span region="Default">Makanya gue mau cerita sama Juragan.<br/>Tapi 'kan, engga keluar.</span></p>
      <p
        begin="01:25:54.500"
        end="01:25:56.541"><span region="Default">Ya, lu tulis aja nama dukun santetnya?</span></p>
      <p
        begin="01:25:57.208"
        end="01:25:58.541"><span region="Default">Ini, lu tulis.</span></p>
      <p
        begin="01:25:58.625"
        end="01:26:00.375"><span region="Default">Gue engga bisa baca tulis.</span></p>
      <p
        begin="01:26:00.458"
        end="01:26:03.583"><span region="Default">Waduh, udah gagap, buta huruf lagi lu.</span></p>
      <p
        begin="01:26:03.666"
        end="01:26:05.250"><span region="Default">Emang lu bisa baca tulis?</span></p>
      <p
        begin="01:26:06.000"
        end="01:26:08.000"><span region="Default">- Enga bisa.<br/>- Payah.</span></p>
      <p
        begin="01:26:08.541"
        end="01:26:10.875"><span region="Default">Udah, gue pusing denger omongan lu berdua.</span></p>
      <p
        begin="01:26:10.958"
        end="01:26:14.541"><span region="Default">Gimana kita mau maju,<br/>kalau kualitas SDM kita rendah begini?</span></p>
      <p
        begin="01:26:21.000"
        end="01:26:22.791"><span region="Default">Kenapa sih, orang-orang?</span></p>
      <p
        begin="01:26:22.875"
        end="01:26:24.666"><span region="Default">Padahal 'kan, gue cuma mau cerita</span></p>
      <p
        begin="01:26:24.750"
        end="01:26:26.791"><span region="Default">dukun santetnya itu Suzzanna.</span></p>
      <p
        begin="01:26:27.375"
        end="01:26:29.291"><span region="Default">Kok bisa?</span></p>
      <p
        begin="01:26:30.125"
        end="01:26:32.916"><span region="Default">Kayaknya gue disantet.</span></p>
      <p
        begin="01:28:42.833"
        end="01:28:45.666"><span region="Default">Berantakan dari dunia,</span></p>
      <p
        begin="01:28:45.750"
        end="01:28:47.250"><span region="Default">hancur semuanya.</span></p>
      <p
        begin="01:29:01.458"
        end="01:29:03.791"><span region="Default">Bersih tanpa sisa.</span></p>
      <p
        begin="01:30:25.791"
        end="01:30:26.833"><span region="Default">Kamu hebat.</span></p>
      <p
        begin="01:30:27.583"
        end="01:30:29.291"><span region="Default">Berbulan-bulan minggat dari Karang Setan.</span></p>
      <p
        begin="01:30:30.250"
        end="01:30:32.041"><span region="Default">Pulang-pulang pintar nyantet.</span></p>
      <p
        begin="01:30:32.666"
        end="01:30:33.666"><span region="Default">Tapi sayang.</span></p>
      <p
        begin="01:30:33.750"
        end="01:30:36.375"><span region="Default">Kamu terlalu tinggi<br/>menilai dirimu sendiri.</span></p>
      <p
        begin="01:30:37.083"
        end="01:30:39.666"><span region="Default">Dan menganggap<br/>semua orang bisa kamu kalahkan.</span></p>
      <p
        begin="01:30:39.750"
        end="01:30:42.333"><span region="Default">Saya memang tidak pernah belajar santet.</span></p>
      <p
        begin="01:30:43.291"
        end="01:30:44.708"><span region="Default">Tapi asal kamu tahu,</span></p>
      <p
        begin="01:30:44.791"
        end="01:30:48.583"><span region="Default">dari Ponorogo, sampai ke Banyuwangi,</span></p>
      <p
        begin="01:30:49.625"
        end="01:30:52.000"><span region="Default">banyak dukun santet yang saya kenal.</span></p>
      <p
        begin="01:30:53.291"
        end="01:30:56.708"><span region="Default">Dan semua ngasih saya<br/>pegangan buat penangkal kiriman.</span></p>
      <p
        begin="01:30:58.708"
        end="01:31:00.291"><span region="Default">Sudahlah.</span></p>
      <p
        begin="01:31:00.375"
        end="01:31:02.625"><span region="Default">Lupakan kejadian yang sudah lewat.</span></p>
      <p
        begin="01:31:03.833"
        end="01:31:05.791"><span region="Default">Lebih baik kamu fokus</span></p>
      <p
        begin="01:31:05.875"
        end="01:31:07.625"><span region="Default">pada masa depanmu yang lebih baik.</span></p>
      <p
        begin="01:31:08.375"
        end="01:31:10.375"><span region="Default">Dengan menerima lamaran saya.</span></p>
      <p
        begin="01:31:14.166"
        end="01:31:16.208"><span region="Default">Saya masih menunggu.</span></p>
      <p
        begin="01:31:16.791"
        end="01:31:19.708"><span region="Default">Pak Bisman lunasi syarat yang saya ajukan.</span></p>
      <p
        begin="01:31:20.708"
        end="01:31:22.750"><span region="Default">Saya sudah bantu habisi dua.</span></p>
      <p
        begin="01:31:23.916"
        end="01:31:26.916"><span region="Default">Sisa satu lagi, yang masih hidup.</span></p>
      <p
        begin="01:31:48.291"
        end="01:31:52.666"><span region="Default">Besok subuh, antar saya ke Ponorogo.<br/>Saya mau sowan Mbah Kodrat.</span></p>
      <p
        begin="01:31:55.666"
        end="01:31:57.166"><span region="Default">Kamu sadar,</span></p>
      <p
        begin="01:31:57.250"
        end="01:32:03.166"><span region="Default">apa yang bisa terjadi kalau aku mengirim<br/>santet paruh jiwo ke calon istrimu?</span></p>
      <p
        begin="01:32:03.250"
        end="01:32:06.083"><span region="Default">- Sadar, Mbah.<br/>- Memang kamu engga kecewa?</span></p>
      <p
        begin="01:32:06.666"
        end="01:32:09.083"><span region="Default">Kawin dengan perempuan<br/>yang sama sekali beda?</span></p>
      <p
        begin="01:32:10.208"
        end="01:32:11.375"><span region="Default">Engga, Mbah.</span></p>
      <p
        begin="01:32:12.208"
        end="01:32:13.583"><span region="Default">Lebih baik seperti itu.</span></p>
      <p
        begin="01:32:14.666"
        end="01:32:19.041"><span region="Default">Daripada dia mengenali saya<br/>tapi seumur-umur membenci saya.</span></p>
      <p
        begin="01:33:39.958"
        end="01:33:42.166"><span region="Default">Kamu tahu kamu ada di mana?</span></p>
      <p
        begin="01:33:47.750"
        end="01:33:49.708"><span region="Default">Nama kamu siapa?</span></p>
      <p
        begin="01:33:53.000"
        end="01:33:54.875"><span region="Default">Kalau kamu tidak tahu siapa namamu,</span></p>
      <p
        begin="01:33:55.666"
        end="01:33:58.708"><span region="Default">saya kasih saja kamu nama Suzzanna.</span></p>
      <p
        begin="01:34:23.666"
        end="01:34:25.416"><span region="Default">Sekarang kamu makan dulu, ya?</span></p>
      <p
        begin="01:34:26.458"
        end="01:34:28.708"><span region="Default">Dari kemarin kamu belum makan.</span></p>
      <p
        begin="01:34:52.333"
        end="01:34:54.166"><span region="Default">Kenapa kamu balik lagi ke sini?</span></p>
      <p
        begin="01:34:55.083"
        end="01:34:56.791"><span region="Default">Karena saya masih ingin<br/>mencari bapak saya.</span></p>
      <p
        begin="01:34:56.875"
        end="01:34:59.791"><span region="Default">- Siapa nama ibumu?<br/>- Astuti.</span></p>
      <p
        begin="01:35:06.625"
        end="01:35:07.875"><span region="Default">Ini fotonya.</span></p>
      <p
        begin="01:35:07.958"
        end="01:35:11.458"><span region="Default">Tapi saya tidak punya foto bapak saya.<br/>Ibu bilang, Bapak seorang pelaut.</span></p>
      <p
        begin="01:35:12.500"
        end="01:35:15.750"><span region="Default">Dan mengalami musibah<br/>saat ibu saya melahirkan saya.</span></p>
      <p
        begin="01:35:26.833"
        end="01:35:28.291"><span region="Default">Bapakmu bohong.</span></p>
      <p
        begin="01:35:30.208"
        end="01:35:31.375"><span region="Default">Dia bukan pelaut.</span></p>
      <p
        begin="01:35:32.041"
        end="01:35:34.166"><span region="Default">Namanya juga bukan Kasman.</span></p>
      <p
        begin="01:35:34.250"
        end="01:35:38.083"><span region="Default">Dia memalsukan namanya<br/>dan mengaku-ngaku sebagai pelaut,</span></p>
      <p
        begin="01:35:38.166"
        end="01:35:41.291"><span region="Default">buat cari alasan<br/>bisa sering-sering meninggalkan ibumu.</span></p>
      <p
        begin="01:35:41.375"
        end="01:35:43.750"><span region="Default">Karena pacarnya ada di mana-mana.</span></p>
      <p
        begin="01:35:44.500"
        end="01:35:46.208"><span region="Default">Setelah itu bapakmu pergi dari desa ini,<br/>dan tidak pernah kembali lagi.</span></p>
      <p
        begin="01:35:49.333"
        end="01:35:50.541"><span region="Default">Bapak tahu di mana bapak saya?</span></p>
      <p
        begin="01:35:50.625"
        end="01:35:52.916"><span region="Default">Saya akan kasih tahu di mana bapakmu,</span></p>
      <p
        begin="01:35:53.000"
        end="01:35:56.208"><span region="Default">tapi kamu jawab dulu<br/>pertanyaan-pertanyaanku dengan jujur.</span></p>
      <p
        begin="01:35:56.291"
        end="01:35:58.333"><span region="Default">Insya Allah akan saya jawab<br/>dengan jujur, Pak.</span></p>
      <p
        begin="01:36:00.041"
        end="01:36:02.708"><span region="Default">Apa sebenarnya tujuanmu<br/>datang ke Karang Setan?</span></p>
      <p
        begin="01:36:03.791"
        end="01:36:05.958"><span region="Default">- Ya ingin mencari bapak saya.<br/>- Bohong.</span></p>
      <p
        begin="01:36:06.583"
        end="01:36:09.166"><span region="Default">Tujuan kamu ke Karang Setan<br/>untuk mengejar Suzzanna, 'kan?</span></p>
      <p
        begin="01:36:09.250"
        end="01:36:11.750"><span region="Default">- Bukan.<br/>- Apa hubungan kamu dengan Suzzanna?</span></p>
      <p
        begin="01:36:11.833"
        end="01:36:13.583"><span region="Default">Sampai merasa perlu datang ke sini?</span></p>
      <p
        begin="01:36:13.666"
        end="01:36:15.333"><span region="Default">Kamu cinta sama dia?</span></p>
      <p
        begin="01:36:22.166"
        end="01:36:25.041"><span region="Default">Untuk apa Bapak menanyakan<br/>hubungan saya dengan Suzzanna?</span></p>
      <p
        begin="01:36:25.666"
        end="01:36:28.208"><span region="Default">Karena sebentar lagi dia<br/>akan menikah dengan saya.</span></p>
      <p
        begin="01:36:29.750"
        end="01:36:34.166"><span region="Default">Dan saya harus memastikan<br/>tak ada orang lain yang merasa keberatan.</span></p>
      <p
        begin="01:36:34.250"
        end="01:36:36.541"><span region="Default">Suzzanna tidak akan menikah dengan Bapak.</span></p>
      <p
        begin="01:36:37.625"
        end="01:36:39.333"><span region="Default">Kecuali Bapak memaksa.</span></p>
      <p
        begin="01:36:40.208"
        end="01:36:41.875"><span region="Default">Selama saya masih hidup,</span></p>
      <p
        begin="01:36:42.666"
        end="01:36:45.875"><span region="Default">saya akan pastikan<br/>hal itu tidak akan pernah terjadi.</span></p>
      <p
        begin="01:36:46.541"
        end="01:36:48.208"><span region="Default">Kita lihat saja.</span></p>
      <p
        begin="01:37:04.666"
        end="01:37:06.041"><span region="Default">Suzzanna.</span></p>
      <p
        begin="01:37:07.500"
        end="01:37:10.583"><span region="Default">Taruh sapunya. Kita bicara di dalam.</span></p>
      <p
        begin="01:37:14.166"
        end="01:37:15.041"><span region="Default">Suzzanna?</span></p>
      <p
        begin="01:37:16.625"
        end="01:37:18.125"><span region="Default">Kamu siapa?</span></p>
      <p
        begin="01:37:22.000"
        end="01:37:25.208"><span region="Default">Sudah, kamu tunggu saja di dalam. Ya?</span></p>
      <p
        begin="01:37:35.208"
        end="01:37:36.750"><span region="Default">Kau apakan dia?</span></p>
      <p
        begin="01:37:37.791"
        end="01:37:40.041"><span region="Default">Dukun santet mana<br/>yang kamu pakai untuk merusak pikirannya?</span></p>
      <p
        begin="01:37:40.125"
        end="01:37:41.291"><span region="Default">Bukan urusanmu.</span></p>
      <p
        begin="01:37:42.041"
        end="01:37:44.250"><span region="Default">Sebentar lagi dia akan menjadi istriku.</span></p>
      <p
        begin="01:37:51.625"
        end="01:37:52.833"><span region="Default">Sudah, sudah!</span></p>
      <p
        begin="01:37:53.458"
        end="01:37:55.541"><span region="Default">Kita habisi saja dia, Gan.</span></p>
      <p
        begin="01:37:56.208"
        end="01:37:59.416"><span region="Default">Jangan. Kasih dia bekal<br/>buat pulang ke Kalinegoro.</span></p>
      <p
        begin="01:38:00.958"
        end="01:38:02.041"><span region="Default">Bawa dia.</span></p>
      <p
        begin="01:38:42.333"
        end="01:38:43.500"><span region="Default">Siape lu?</span></p>
      <p
        begin="01:38:46.375"
        end="01:38:47.791"><span region="Default">Petugas kelurahan, 'kan?</span></p>
      <p
        begin="01:38:48.708"
        end="01:38:50.875"><span region="Default">Trus mau apa<br/>masuk-masuk kamar pengantin begini?</span></p>
      <p
        begin="01:38:50.958"
        end="01:38:52.291"><span region="Default">Mau dihajar sama Pak Lurah?</span></p>
      <p
        begin="01:38:52.375"
        end="01:38:55.083"><span region="Default">Bukan! Gue engga bermaksud apa-apa<br/>sama Suzzanna.</span></p>
      <p
        begin="01:38:55.166"
        end="01:38:58.000"><span region="Default">- Sumpah!<br/>- Kalau tidak bermaksud apa-apa,</span></p>
      <p
        begin="01:38:58.833"
        end="01:39:00.208"><span region="Default">kenapa harus seperti maling begini?</span></p>
      <p
        begin="01:39:00.291"
        end="01:39:03.375"><span region="Default">Lu sendiri ngapain di mari? Jangan-jangan…</span></p>
      <p
        begin="01:39:04.125"
        end="01:39:07.291"><span region="Default">- Lu maling teriak maling, ya?<br/>- Saya kemari mau menolong Suzzanna.</span></p>
      <p
        begin="01:39:07.375"
        end="01:39:08.541"><span region="Default">Gue juga!</span></p>
      <p
        begin="01:39:10.083"
        end="01:39:11.708"><span region="Default">- Bisa bantu saya?<br/>- Bisa.</span></p>
      <p
        begin="01:39:33.083"
        end="01:39:34.625"><span region="Default">- Ayo angkat.<br/>- Ayo.</span></p>
      <p
        begin="01:39:34.708"
        end="01:39:36.541"><span region="Default">Awas, awas kepalanya.</span></p>
      <p
        begin="01:39:36.625"
        end="01:39:37.666"><span region="Default">Tolong.</span></p>
      <p
        begin="01:39:38.833"
        end="01:39:40.208"><span region="Default">Tarik.</span></p>
      <p
        begin="01:39:44.541"
        end="01:39:47.750"><span region="Default">- Wah, udah insyaf nih?<br/>- Setan alas lu!</span></p>
      <p
        begin="01:40:06.041"
        end="01:40:07.083"><span region="Default">Bude?</span></p>
      <p
        begin="01:40:17.833"
        end="01:40:19.083"><span region="Default">Suzzanna?</span></p>
      <p
        begin="01:40:20.041"
        end="01:40:23.041"><span region="Default">Maaf, Bude. Saya terpaksa datang kemari.</span></p>
      <p
        begin="01:40:23.708"
        end="01:40:24.958"><span region="Default">Demi Suzzanna.</span></p>
      <p
        begin="01:40:25.583"
        end="01:40:27.083"><span region="Default">Ada orang yang membuatnya lupa ingatan.</span></p>
      <p
        begin="01:40:27.166"
        end="01:40:30.208"><span region="Default">Santet Paruh Jiwo.</span></p>
      <p
        begin="01:40:31.833"
        end="01:40:34.166"><span region="Default">Tubuhnya cukup kuat<br/>untuk tidak membuatnya gila.</span></p>
      <p
        begin="01:40:35.166"
        end="01:40:38.250"><span region="Default">Tapi pengobatan yang Bude ajarkan<br/>belum saya kuasai.</span></p>
      <p
        begin="01:40:38.333"
        end="01:40:42.041"><span region="Default">Kamu tidak usah belajar<br/>yang aneh-aneh kayak Bude.</span></p>
      <p
        begin="01:40:42.916"
        end="01:40:45.083"><span region="Default">Ayo. Masuk.</span></p>
      <p
        begin="01:40:46.041"
        end="01:40:47.166"><span region="Default">Ayo.</span></p>
      <p
        begin="01:40:50.708"
        end="01:40:51.791"><span region="Default">Ayo, Nduk.</span></p>
      <p
        begin="01:40:53.166"
        end="01:40:54.375"><span region="Default">Ayo.</span></p>
      <p
        begin="01:41:03.208"
        end="01:41:05.875"><span region="Default">Kalau Bude tidak keberatan,<br/>saya titipkan dulu Suzzanna di sini.</span></p>
      <p
        begin="01:41:07.583"
        end="01:41:10.125"><span region="Default">Saya masih ada urusan di Karang Setan.</span></p>
      <p
        begin="01:41:15.041"
        end="01:41:16.958"><span region="Default">Dengan senang hati, Le.</span></p>
      <p
        begin="01:41:19.208"
        end="01:41:20.708"><span region="Default">Hati-hati, ya?</span></p>
      <p
        begin="01:41:27.083"
        end="01:41:28.916"><span region="Default">Maafkan Bude.</span></p>
      <p
        begin="01:41:33.583"
        end="01:41:36.041"><span region="Default">Kalau kamu masih mau tinggal di sini,</span></p>
      <p
        begin="01:41:37.458"
        end="01:41:39.041"><span region="Default">Bude engga akan usir kamu.</span></p>
      <p
        begin="01:41:40.416"
        end="01:41:43.458"><span region="Default">Rumah Bude, rumah kamu juga, Le.</span></p>
      <p
        begin="01:42:22.416"
        end="01:42:23.291"><span region="Default">Siapa kamu?</span></p>
      <p
        begin="01:42:23.375"
        end="01:42:24.875"><span region="Default">Kamu sendiri siapa?</span></p>
      <p
        begin="01:42:36.333"
        end="01:42:37.583"><span region="Default">Mau tahu?</span></p>
      <p
        begin="01:42:37.666"
        end="01:42:40.625"><span region="Default">Makanya sekarang…</span></p>
      <p
        begin="01:42:40.708"
        end="01:42:43.083"><span region="Default">Rasakan dulu</span></p>
      <p
        begin="01:42:43.166"
        end="01:42:45.583"><span region="Default">sebelum kamu mati.</span></p>
      <p
        begin="01:43:16.208"
        end="01:43:17.458"><span region="Default">Ayo mengaku.</span></p>
      <p
        begin="01:43:17.541"
        end="01:43:19.208"><span region="Default">Siapa yang menyuruhmu</span></p>
      <p
        begin="01:43:19.291"
        end="01:43:20.750"><span region="Default">mengganggu Suzzanna?</span></p>
      <p
        begin="01:43:21.541"
        end="01:43:23.291"><span region="Default">Bukan urusanmu!</span></p>
      <p
        begin="01:43:24.541"
        end="01:43:26.125"><span region="Default">Pasti jadi urusanku.</span></p>
      <p
        begin="01:43:27.083"
        end="01:43:28.750"><span region="Default">Siapa yang berani</span></p>
      <p
        begin="01:43:28.833"
        end="01:43:31.750"><span region="Default">mengganggu Suzzanna<br/>akan berurusan denganku.</span></p>
      <p
        begin="01:44:00.291"
        end="01:44:01.208"><span region="Default">Gawat.</span></p>
      <p
        begin="01:44:37.208"
        end="01:44:40.958"><span region="Default">Sekarang waktunya kamu mati.</span></p>
      <p
        begin="01:44:44.583"
        end="01:44:47.541"><span region="Default">Mati kamu Gayatri. Mati!</span></p>
      <p
        begin="01:44:50.375"
        end="01:44:56.791"><span region="Default">Sekarang waktunya kamu pergi.</span></p>
      <p
        begin="01:45:01.208"
        end="01:45:02.500"><span region="Default">Heh!</span></p>
      <p
        begin="01:45:03.291"
        end="01:45:09.500"><span region="Default">Aku tahu nyawamu, ada di tenggorokanmu.</span></p>
      <p
        begin="01:45:14.041"
        end="01:45:15.416"><span region="Default">Kalau aku ikat,</span></p>
      <p
        begin="01:45:15.958"
        end="01:45:18.291"><span region="Default">bisa jadi bonekaku.</span></p>
      <p
        begin="01:45:21.041"
        end="01:45:26.041"><span region="Default">Hadapi dulu cahaya bulan purnama,</span></p>
      <p
        begin="01:45:26.125"
        end="01:45:27.958"><span region="Default">dukun tua!</span></p>
      <p
        begin="01:46:34.333"
        end="01:46:35.416"><span region="Default">Tohir.</span></p>
      <p
        begin="01:46:35.500"
        end="01:46:36.875"><span region="Default">Gimana?</span></p>
      <p
        begin="01:46:37.458"
        end="01:46:39.375"><span region="Default">- Engga ketemu.<br/>- Masa engga ketemu?</span></p>
      <p
        begin="01:46:39.458"
        end="01:46:41.625"><span region="Default">- Aduh!<br/>- Hei, mana Kliwon?</span></p>
      <p
        begin="01:46:41.708"
        end="01:46:43.708"><span region="Default">Lagi dirias Juragan. Eh?</span></p>
      <p
        begin="01:46:43.791"
        end="01:46:45.625"><span region="Default">Memangnya Kliwon yang mau kawin?</span></p>
      <p
        begin="01:46:45.708"
        end="01:46:49.416"><span region="Default">- Maaf Juragan, maksud saya…<br/>- Suzzanna sudah selesai dirias?</span></p>
      <p
        begin="01:46:49.500"
        end="01:46:51.666"><span region="Default">Saya cari-cari engga ketemu, Juragan.</span></p>
      <p
        begin="01:46:51.750"
        end="01:46:55.000"><span region="Default">Aku ini nanya Suzzanna.<br/>Engga ada urusan soal Kliwon.</span></p>
      <p
        begin="01:46:55.083"
        end="01:46:58.583"><span region="Default">Saya juga jawab soal<br/>Mbak Suzzanna. Bukan soal Kliwon.</span></p>
      <p
        begin="01:46:58.666"
        end="01:47:01.833"><span region="Default">Tadi kenapa kamu bilang engga ketemu?<br/>Memangnya Suzzanna hilang?</span></p>
      <p
        begin="01:47:01.916"
        end="01:47:04.625"><span region="Default">Kalau engga hilang,<br/>saya engga cari-cari, Juragan.</span></p>
      <p
        begin="01:47:04.708"
        end="01:47:07.541"><span region="Default">- Kamu juga engga tau di mana Suzzanna?<br/>- Engga tau, Juragan.</span></p>
      <p
        begin="01:47:08.750"
        end="01:47:12.083"><span region="Default">Kawi! Mana Suzzanna?</span></p>
      <p
        begin="01:47:20.708"
        end="01:47:24.250"><span region="Default">Sepertinya dia ingin membunuh jiwamu.</span></p>
      <p
        begin="01:47:25.458"
        end="01:47:27.458"><span region="Default">Tanpa merusak ragamu.</span></p>
      <p
        begin="01:47:28.958"
        end="01:47:31.666"><span region="Default">Izinkanlah saya belajar ilmu untuk</span></p>
      <p
        begin="01:47:31.750"
        end="01:47:33.791"><span region="Default">melunturkan penangkal<br/>yang dia miliki, Nyi.</span></p>
      <p
        begin="01:47:33.875"
        end="01:47:37.375"><span region="Default">Pertahanan dia begitu kuat<br/>untuk saya lawan.</span></p>
      <p
        begin="01:47:39.541"
        end="01:47:41.791"><span region="Default">Kalau penangkal yang dimiliki,</span></p>
      <p
        begin="01:47:42.750"
        end="01:47:44.000"><span region="Default">biar aku atasi.</span></p>
      <p
        begin="01:47:45.458"
        end="01:47:47.541"><span region="Default">Tapi untuk menyerang dia,</span></p>
      <p
        begin="01:47:47.625"
        end="01:47:50.291"><span region="Default">sebenarnya ada satu serangan</span></p>
      <p
        begin="01:47:50.375"
        end="01:47:53.958"><span region="Default">yang belum aku ajarkan<br/>karena terlalu berbahaya.</span></p>
      <p
        begin="01:47:54.041"
        end="01:47:55.708"><span region="Default">Namanya</span></p>
      <p
        begin="01:47:56.541"
        end="01:47:58.750"><span region="Default">Santet Pring Sedapur.</span></p>
      <p
        begin="01:47:59.500"
        end="01:48:02.625"><span region="Default">Kekuatannya sama besar<br/>dengan Samber Nyowo,</span></p>
      <p
        begin="01:48:02.708"
        end="01:48:07.291"><span region="Default">tapi bukan cuma si Bisman yang akan kena.</span></p>
      <p
        begin="01:48:08.333"
        end="01:48:12.083"><span region="Default">Anak turunnya semua juga akan binasa.</span></p>
      <p
        begin="01:48:12.958"
        end="01:48:15.500"><span region="Default">Bisman tidak memiliki anak turunan, Nyi.</span></p>
      <p
        begin="01:48:17.375"
        end="01:48:20.500"><span region="Default">Tidak akan ada<br/>korban selain hanya dirinya.</span></p>
      <p
        begin="01:48:21.375"
        end="01:48:23.000"><span region="Default">Aku akan memberikannya</span></p>
      <p
        begin="01:48:23.625"
        end="01:48:25.750"><span region="Default">tapi hanya untuk satu serangan.</span></p>
      <p
        begin="01:48:25.833"
        end="01:48:28.208"><span region="Default">Dan ini tidak bisa dibatalkan.</span></p>
      <p
        begin="01:48:29.041"
        end="01:48:30.916"><span region="Default">Kalau kamu batalkan,</span></p>
      <p
        begin="01:48:31.625"
        end="01:48:36.000"><span region="Default">kekuatan pemusnahnya<br/>akan kembali menghantam pengirimnya.</span></p>
      <p
        begin="01:48:37.000"
        end="01:48:38.791"><span region="Default">Ke kamu.</span></p>
      <p
        begin="01:48:53.166"
        end="01:48:54.625"><span region="Default">Dengar semuanya.</span></p>
      <p
        begin="01:48:55.916"
        end="01:48:58.208"><span region="Default">Ini perintah Juragan Bisman.</span></p>
      <p
        begin="01:48:59.166"
        end="01:49:04.708"><span region="Default">Kalian semua harus bekerja sama<br/>mencari Suzzanna sampai ketemu.</span></p>
      <p
        begin="01:49:04.791"
        end="01:49:07.833"><span region="Default">Jika sampai maghrib nanti<br/>Suzzanna tidak ketemu juga,</span></p>
      <p
        begin="01:49:08.416"
        end="01:49:10.750"><span region="Default">kalian yang harus menanggung akibatnya.</span></p>
      <p
        begin="01:49:11.791"
        end="01:49:15.416"><span region="Default">Juragan Bisman hanya akan<br/>kasih waktu kalian sampai besok malam.</span></p>
      <p
        begin="01:49:16.000"
        end="01:49:19.125"><span region="Default">Untuk kalian lunasi utang-utang kalian.</span></p>
      <p
        begin="01:49:21.750"
        end="01:49:23.708"><span region="Default">Apa?</span></p>
      <p
        begin="01:49:24.291"
        end="01:49:28.166"><span region="Default">Kalau tidak setuju, maju!<br/>Jangan menggerutu di belakang.</span></p>
      <p
        begin="01:49:29.333"
        end="01:49:31.208"><span region="Default">Kenapa pada bengong?</span></p>
      <p
        begin="01:49:32.125"
        end="01:49:33.958"><span region="Default">Bubar!</span></p>
      <p
        begin="01:49:34.041"
        end="01:49:36.375"><span region="Default">Cepat cari Suzzanna sampai ketemu!</span></p>
      <p
        begin="01:49:36.458"
        end="01:49:38.166"><span region="Default">Itu bukan tugas mereka.</span></p>
      <p
        begin="01:49:39.000"
        end="01:49:39.833"><span region="Default">Eh?</span></p>
      <p
        begin="01:49:40.916"
        end="01:49:42.458"><span region="Default">Siapa yang ngomong?</span></p>
      <p
        begin="01:49:52.458"
        end="01:49:54.250"><span region="Default">Saya memang bukan orang sini.</span></p>
      <p
        begin="01:49:55.375"
        end="01:49:56.666"><span region="Default">Tapi saya tahu ini hanya akal-akalan</span></p>
      <p
        begin="01:49:56.750"
        end="01:49:58.750"><span region="Default">kalian saja untuk membuat mereka<br/>membayar utang.</span></p>
      <p
        begin="01:49:59.625"
        end="01:50:03.208"><span region="Default">Jangan main-main<br/>sama perintah Juragan Bisman.</span></p>
      <p
        begin="01:50:03.291"
        end="01:50:05.333"><span region="Default">Orang paling bodoh<br/>di desa ini pun tahu kalau</span></p>
      <p
        begin="01:50:05.416"
        end="01:50:07.000"><span region="Default">perintah itu adalah perintah<br/>yang tidak masuk akal.</span></p>
      <p
        begin="01:50:07.083"
        end="01:50:09.416"><span region="Default">Kasih-kasihin nih, cepetan.</span></p>
      <p
        begin="01:50:09.500"
        end="01:50:13.416"><span region="Default">Kalau memang Suzzanna menghilang,<br/>dia bisa saja lari ke Ngawi,</span></p>
      <p
        begin="01:50:13.500"
        end="01:50:15.458"><span region="Default">Jombang, Kediri,</span></p>
      <p
        begin="01:50:15.541"
        end="01:50:18.625"><span region="Default">lalu kalian mau menyuruh mereka semua<br/>untuk mencari Suzzanna ke seluruh desa?</span></p>
      <p
        begin="01:50:18.708"
        end="01:50:21.500"><span region="Default">Kota-kota? Kalian mau<br/>disuruh cari Suzzanna ke mana-mana?</span></p>
      <p
        begin="01:50:21.583"
        end="01:50:24.500"><span region="Default">- Engga!<br/>- Engga mau, engga!</span></p>
      <p
        begin="01:50:24.583"
        end="01:50:26.750"><span region="Default">- Diam!<br/>- Tidak mau!</span></p>
      <p
        begin="01:50:26.833"
        end="01:50:30.000"><span region="Default">Mau ada urusan dengan Suzzanna atau tidak,</span></p>
      <p
        begin="01:50:30.083"
        end="01:50:32.250"><span region="Default">utang tetap utang.</span></p>
      <p
        begin="01:50:32.333"
        end="01:50:33.750"><span region="Default">Siapa yang membuat mereka berutang?</span></p>
      <p
        begin="01:50:35.500"
        end="01:50:36.375"><span region="Default">Kamu pasti tahu.</span></p>
      <p
        begin="01:50:36.958"
        end="01:50:38.166"><span region="Default">Lima tahun yang lalu,</span></p>
      <p
        begin="01:50:38.250"
        end="01:50:41.708"><span region="Default">Juragan Bisman sengaja menyebar hama,<br/>dan merusak seluruh sawah di desa ini.</span></p>
      <p
        begin="01:50:42.291"
        end="01:50:43.500"><span region="Default">Puluhan hektar jumlahnya.</span></p>
      <p
        begin="01:50:44.375"
        end="01:50:45.750"><span region="Default">Lalu setelah gagal panen,<br/>apa yang terjadi?</span></p>
      <p
        begin="01:50:45.833"
        end="01:50:49.125"><span region="Default">Mereka semua terpaksa berutang<br/>kepada Juragan Bisman.</span></p>
      <p
        begin="01:50:49.208"
        end="01:50:52.000"><span region="Default">Lalu, untuk bisa membayar utangnya,<br/>mereka menggadaikan sawahnya.</span></p>
      <p
        begin="01:50:52.083"
        end="01:50:54.041"><span region="Default">Menjadi buruh dan bekerja untuk sawah</span></p>
      <p
        begin="01:50:54.125"
        end="01:50:56.333"><span region="Default">mereka sendiri yang sudah dimiliki<br/>Juragan Bisman, betul tidak?</span></p>
      <p
        begin="01:50:56.416"
        end="01:50:58.250"><span region="Default">Betul itu, betul sekali!</span></p>
      <p
        begin="01:50:58.833"
        end="01:51:00.750"><span region="Default">Saya sendiri yang mengalami.</span></p>
      <p
        begin="01:51:00.833"
        end="01:51:02.500"><span region="Default">Ini yang namanya penjajahan.</span></p>
      <p
        begin="01:51:03.083"
        end="01:51:04.208"><span region="Default">Zolim.</span></p>
      <p
        begin="01:51:05.541"
        end="01:51:07.666"><span region="Default">Mengejar kekayaan untuk mendapatkan kuasa.</span></p>
      <p
        begin="01:51:08.416"
        end="01:51:10.291"><span region="Default">Menggunakan kekuasaan<br/>untuk menjadikan diri semakin kaya</span></p>
      <p
        begin="01:51:10.375"
        end="01:51:12.125"><span region="Default">dengan menyengsarakan orang lain.</span></p>
      <p
        begin="01:51:12.208"
        end="01:51:13.791"><span region="Default">Mau kalian terus-terusan dijajah?</span></p>
      <p
        begin="01:51:13.875"
        end="01:51:15.541"><span region="Default">Tidak!</span></p>
      <p
        begin="01:51:15.625"
        end="01:51:17.250"><span region="Default">Mau kalian terus-terusan dizolimi?</span></p>
      <p
        begin="01:51:17.333"
        end="01:51:23.125"><span region="Default">- Tidak!<br/>- Tidak!</span></p>
      <p
        begin="01:51:23.208"
        end="01:51:25.458"><span region="Default">Tukang fitnah. Hajar dia. Tangkap!</span></p>
      <p
        begin="01:52:26.416"
        end="01:52:29.333"><span region="Default">Kita harus menyelamatkan<br/>brankas uang di lemari kafe.</span></p>
      <p
        begin="01:52:58.416"
        end="01:53:00.958"><span region="Default">Bisman! Mana kamu?</span></p>
      <p
        begin="01:53:04.000"
        end="01:53:05.500"><span region="Default">Ayo, Juragan.</span></p>
      <p
        begin="01:53:09.333"
        end="01:53:12.041"><span region="Default">Bisman kabur!</span></p>
      <p
        begin="01:53:12.125"
        end="01:53:15.000"><span region="Default">Bisman! Jangan lari kamu!</span></p>
      <p
        begin="01:53:15.083"
        end="01:53:18.041"><span region="Default">Bisman!</span></p>
      <p
        begin="01:53:35.750"
        end="01:53:37.958"><span region="Default">Ayo!</span></p>
      <p
        begin="01:53:48.833"
        end="01:53:50.541"><span region="Default">Hei, kunci semua pintu!</span></p>
      <p
        begin="01:53:55.208"
        end="01:53:58.291"><span region="Default">Ayo teman-teman! Ayo!</span></p>
      <p
        begin="01:54:08.666"
        end="01:54:10.041"><span region="Default">Kuncinya di rumah.</span></p>
      <p
        begin="01:54:15.625"
        end="01:54:17.666"><span region="Default">Serang, jangan takut!</span></p>
      <p
        begin="01:55:10.916"
        end="01:55:11.958"><span region="Default">Ini, Juragan.</span></p>
      <p
        begin="01:55:24.708"
        end="01:55:26.250"><span region="Default">Tunggu di sini, Juragan.</span></p>
      <p
        begin="01:56:11.000"
        end="01:56:12.291"><span region="Default">Mampus!</span></p>
      <p
        begin="01:56:25.291"
        end="01:56:26.500"><span region="Default">Bisman!</span></p>
      <p
        begin="01:56:56.541"
        end="01:57:00.208"><span region="Default">Saya mohon pertolonganmu.</span></p>
      <p
        begin="01:57:38.666"
        end="01:57:40.041"><span region="Default">Juragan…</span></p>
      <p
        begin="01:58:47.541"
        end="01:58:48.666"><span region="Default">Tolong aku.</span></p>
      <p
        begin="01:58:49.666"
        end="01:58:50.958"><span region="Default">Tolong.</span></p>
      <p
        begin="01:59:04.583"
        end="01:59:05.541"><span region="Default">Sebentar.</span></p>
      <p
        begin="01:59:06.458"
        end="01:59:07.333"><span region="Default">Tolong…</span></p>
      <p
        begin="01:59:57.541"
        end="01:59:58.375"><span region="Default">Suzzanna.</span></p>
      <p
        begin="01:59:59.916"
        end="02:00:01.458"><span region="Default">Aku merasa tidak pantas, Mas.</span></p>
      <p
        begin="02:00:02.375"
        end="02:00:05.958"><span region="Default">- Menghadapi almarhum Bapak dan Ibu.<br/>- Suzzanna.</span></p>
      <p
        begin="02:00:06.041"
        end="02:00:07.916"><span region="Default">Kau hanya perlu melakukan satu hal.</span></p>
      <p
        begin="02:00:09.416"
        end="02:00:11.875"><span region="Default">Buang jauh-jauh ilmu kanuraganmu.</span></p>
      <p
        begin="02:00:11.958"
        end="02:00:13.666"><span region="Default">Aku bisa membantumu.</span></p>
      <p
        begin="02:00:13.750"
        end="02:00:15.916"><span region="Default">Ada seorang kyai di Trenggalek,</span></p>
      <p
        begin="02:00:16.000"
        end="02:00:18.708"><span region="Default">dia bisa membersihkanmu,<br/>bisa menyembuhkanmu.</span></p>
      <p
        begin="02:00:18.791"
        end="02:00:22.000"><span region="Default">- Tak semudah itu.<br/>- Semua tergantung niatmu, Suzzanna.</span></p>
      <p
        begin="02:00:26.666"
        end="02:00:29.375"><span region="Default">Tapi apa Allah mau mengampuni dosa-dosaku?</span></p>
      <p
        begin="02:00:30.666"
        end="02:00:32.333"><span region="Default">Allah Maha Pengampun.</span></p>
      <p
        begin="02:00:35.000"
        end="02:00:37.083"><span region="Default">Kau hanya perlu percaya.</span></p>
      <p
        begin="02:00:43.375"
        end="02:00:44.541"><span region="Default">Terima kasih.</span></p>
      <p
        begin="02:00:48.000"
        end="02:00:49.750"><span region="Default">Kamu selalu menolongku.</span></p>
      <p
        begin="02:00:52.166"
        end="02:00:54.958"><span region="Default">Tidak hanya sekali, tapi dua kali.</span></p>
      <p
        begin="02:00:56.541"
        end="02:00:57.916"><span region="Default">Tiga kali.</span></p>
      <p
        begin="02:00:58.666"
        end="02:01:00.208"><span region="Default">Kau tidak menghitung yang motor.</span></p>
      <p
        begin="02:01:05.166"
        end="02:01:06.333"><span region="Default">Sudah.</span></p>
      <p
        begin="02:01:09.250"
        end="02:01:12.791"><span region="Default">Wah, saya muter-muter nyari<br/>ternyata lagi di sini.</span></p>
      <p
        begin="02:01:12.875"
        end="02:01:14.500"><span region="Default">Ada apa?</span></p>
      <p
        begin="02:01:14.583"
        end="02:01:17.166"><span region="Default">Tadi polisi datang ke kelurahan</span></p>
      <p
        begin="02:01:17.250"
        end="02:01:19.541"><span region="Default">- bawa titipan surat buat Mas Pramuja.<br/>- Iya.</span></p>
      <p
        begin="02:01:19.625"
        end="02:01:23.625"><span region="Default">Kata polisi, ini ditemukan<br/>di ruang tamu rumah Juragan Bisman.</span></p>
      <p
        begin="02:01:24.291"
        end="02:01:25.666"><span region="Default">Buat saya?</span></p>
      <p
        begin="02:01:25.750"
        end="02:01:27.041"><span region="Default">Iya.</span></p>
      <p
        begin="02:01:27.125"
        end="02:01:29.833"><span region="Default">Ya udah, terusin pacarannya.</span></p>
      <p
        begin="02:01:29.916"
        end="02:01:31.625"><span region="Default">Saya doain biar jadi. Aduh!</span></p>
      <p
        begin="02:01:32.250"
        end="02:01:33.500"><span region="Default">Semoga cepet nikah.</span></p>
      <p
        begin="02:01:36.791"
        end="02:01:37.750"><span region="Default">Aduh.</span></p>
      <p
        begin="02:01:40.958"
        end="02:01:42.791"><span region="Default">Bapak…</span></p>
      <p
        begin="02:01:42.875"
        end="02:01:44.625"><span region="Default">ada hubungan dengan Bisman?</span></p>
      <p
        begin="02:01:44.708"
        end="02:01:47.041"><span region="Default">Bisman pernah mengatakan kepada saya kalau</span></p>
      <p
        begin="02:01:48.250"
        end="02:01:49.958"><span region="Default">dia mengenal Bapak.</span></p>
      <p
        begin="02:01:57.625"
        end="02:01:58.958"><span region="Default">Foto Ibu.</span></p>
      <p
        begin="02:01:59.541"
        end="02:02:01.666"><span region="Default">Kenapa Bisman menyimpan foto ibumu?</span></p>
      <p
        begin="02:02:13.583"
        end="02:02:14.916"><span region="Default">Pramuja.</span></p>
      <p
        begin="02:02:15.416"
        end="02:02:20.000"><span region="Default">Baru kali ini aku merasakan<br/>yang namanya bahagia itu seperti apa.</span></p>
      <p
        begin="02:02:20.083"
        end="02:02:22.083"><span region="Default">Yaitu setelah tahu</span></p>
      <p
        begin="02:02:22.166"
        end="02:02:25.666"><span region="Default">bahwa aku punya seorang<br/>anak laki-laki yang sangat baik.</span></p>
      <p
        begin="02:02:25.750"
        end="02:02:27.750"><span region="Default">Beda jauh dengan bapaknya.</span></p>
      <p
        begin="02:02:27.833"
        end="02:02:30.666"><span region="Default">Kamu boleh malu punya bapak seperti aku.</span></p>
      <p
        begin="02:02:30.750"
        end="02:02:32.833"><span region="Default">Tapi aku bangga punya anak seperti kamu.</span></p>
      <p
        begin="02:02:36.416"
        end="02:02:39.958"><span region="Default">Namanya Santet Pring Sedapur.</span></p>
      <p
        begin="02:02:40.041"
        end="02:02:42.875"><span region="Default">Kekuatannya sama besar<br/>dengan Samber Nyowo.</span></p>
      <p
        begin="02:02:42.958"
        end="02:02:47.625"><span region="Default">Tapi bukan cuma si Bisman yang akan kena.</span></p>
      <p
        begin="02:02:47.708"
        end="02:02:51.458"><span region="Default">Anak turunnya semua juga akan binasa.</span></p>
      <p
        begin="02:02:53.916"
        end="02:02:55.541"><span region="Default">Kalau kamu batalkan,</span></p>
      <p
        begin="02:02:55.625"
        end="02:02:59.708"><span region="Default">kekuatan pemusnahnya<br/>akan kembali menghantam pengirimnya.</span></p>
      <p
        begin="02:02:59.791"
        end="02:03:01.375"><span region="Default">Ke kamu.</span></p>
      <p
        begin="02:03:02.458"
        end="02:03:06.458"><span region="Default">Aku minta maaf tidak bisa<br/>menjadi bapak yang baik buatmu.</span></p>
      <p
        begin="02:03:06.541"
        end="02:03:08.000"><span region="Default">Tapi, meskipun tidak mungkin menghapus</span></p>
      <p
        begin="02:03:08.083"
        end="02:03:10.750"><span region="Default">kesalahan-kesalahan<br/>yang pernah aku perbuat,</span></p>
      <p
        begin="02:03:10.833"
        end="02:03:15.041"><span region="Default">aku sudah memutuskan untuk<br/>mewariskan seluruh hartaku untukmu.</span></p>
      <p
        begin="02:03:15.125"
        end="02:03:20.708"><span region="Default">Semoga masih ada celah di hatimu<br/>untuk bisa menerima permintaan maafku ini.</span></p>
      <p
        begin="02:03:48.250"
        end="02:03:49.416"><span region="Default">Suzzanna.</span></p>
      <p
        begin="02:03:50.708"
        end="02:03:51.833"><span region="Default">Suzzanna?</span></p>
      <p
        begin="02:04:04.791"
        end="02:04:05.916"><span region="Default">Suzzanna?</span></p>
      <p
        begin="02:04:26.291"
        end="02:04:27.291"><span region="Default">Suzzanna!</span></p>
      <p
        begin="02:04:29.208"
        end="02:04:32.041"><span region="Default">Suzzanna! Buka! Kamu kenapa? Hei, buka!</span></p>
      <p
        begin="02:04:33.458"
        end="02:04:37.375"><span region="Default">Biarlah aku menanggung<br/>semua akibat perbuatanku, Mas.</span></p>
      <p
        begin="02:04:38.083"
        end="02:04:42.250"><span region="Default">Aku mengirimkan santet itu<br/>tidak hanya untuk Juragan Bisman,</span></p>
      <p
        begin="02:04:43.833"
        end="02:04:48.416"><span region="Default">tapi juga untuk<br/>seluruh anak dan keturunannya.</span></p>
      <p
        begin="02:04:49.000"
        end="02:04:50.458"><span region="Default">Astaghfirullahaladzim.</span></p>
      <p
        begin="02:04:51.041"
        end="02:04:54.166"><span region="Default">Kamu tidak akan menyusul Juragan Bisman.</span></p>
      <p
        begin="02:04:56.958"
        end="02:04:59.375"><span region="Default">Karena serangan itu sudah kubatalkan.</span></p>
      <p
        begin="02:05:01.708"
        end="02:05:03.833"><span region="Default">Dan hanya akan mengenai diriku sendiri.</span></p>
      <p
        begin="02:05:04.500"
        end="02:05:06.666"><span region="Default">Jangan. Jangan, Suzzanna, jangan.</span></p>
      <p
        begin="02:05:06.750"
        end="02:05:08.416"><span region="Default">Pasti ada cara lain.</span></p>
      <p
        begin="02:05:08.500"
        end="02:05:10.958"><span region="Default">Kamu bisa membatalkan semua ini<br/>dengan cara bertaubat.</span></p>
      <p
        begin="02:05:11.541"
        end="02:05:13.458"><span region="Default">Tidak semudah itu, Mas.</span></p>
      <p
        begin="02:05:16.916"
        end="02:05:18.666"><span region="Default">Aku sudah terlalu jauh</span></p>
      <p
        begin="02:05:19.708"
        end="02:05:21.541"><span region="Default">menempuh jalan sesat.</span></p>
      <p
        begin="02:05:21.625"
        end="02:05:25.708"><span region="Default">Jalan kemusyrikan yang tak berampun.</span></p>
      <p
        begin="02:05:26.416"
        end="02:05:28.000"><span region="Default">Dan berdosa.</span></p>
      <p
        begin="02:05:28.083"
        end="02:05:30.625"><span region="Default">Pengampunan itu milik Allah.</span></p>
      <p
        begin="02:05:30.708"
        end="02:05:32.750"><span region="Default">Bukan kita yang menentukan.</span></p>
      <p
        begin="02:05:32.833"
        end="02:05:35.333"><span region="Default">Aku mohon kamu mohon ampun sama Allah.</span></p>
      <p
        begin="02:05:35.416"
        end="02:05:37.916"><span region="Default">Minta tolong sama Allah<br/>selagi masih ada kesempatan.</span></p>
      <p
        begin="02:05:39.208"
        end="02:05:43.125"><span region="Default">Pintu surga<br/>sudah tidak terbuka buatku, Mas.</span></p>
      <p
        begin="02:05:46.500"
        end="02:05:49.750"><span region="Default">Pintu surga sudah tidak terbuka untukku.</span></p>
      <p
        begin="02:06:02.250"
        end="02:06:04.041"><span region="Default">Tapi aku bahagia.</span></p>
      <p
        begin="02:06:09.458"
        end="02:06:14.250"><span region="Default">Melihat Dusun Karang Setan<br/>terbebas dari kezoliman.</span></p>
      <p
        begin="02:06:19.166"
        end="02:06:21.958"><span region="Default">Seperti yang dicita-citakan Bapak.</span></p>
      <p
        begin="02:06:31.041"
        end="02:06:36.666"><span region="Default">Di setiap perubahan<br/>selalu menuntut pengorbanan.</span></p>
      <p
        begin="02:06:38.916"
        end="02:06:41.500"><span region="Default">Suzzanna jangan. Suzzanna!</span></p>
      <p
        begin="02:06:41.583"
        end="02:06:42.791"><span region="Default">Suzzanna?</span></p>
      <p
        begin="02:06:47.958"
        end="02:06:49.416"><span region="Default">Suzzanna?</span></p>
      <p
        begin="02:06:50.125"
        end="02:06:51.500"><span region="Default">Suzzanna?</span></p>
      <p
        begin="02:07:52.541"
        end="02:07:53.916"><span region="Default">Astaghfir…</span></p>
      <p
        begin="02:07:54.000"
        end="02:07:55.500"><span region="Default">Astaghfirullah…</span></p>
      <p
        begin="02:07:55.583"
        end="02:07:59.000"><span region="Default">Astaghfirullah, ya Allah…</span></p>
      <p
        begin="02:08:19.625"
        end="02:08:21.375"><span region="Default">Bapak Ibu sekalian</span></p>
      <p
        begin="02:08:21.458"
        end="02:08:24.375"><span region="Default">warga Karang Setan yang saya hormati,</span></p>
      <p
        begin="02:08:24.458"
        end="02:08:27.583"><span region="Default">ada beberapa hal yang ingin<br/>saya sampaikan kepada Bapak Ibu.</span></p>
      <p
        begin="02:08:28.375"
        end="02:08:30.500"><span region="Default">Saya, Pramuja,</span></p>
      <p
        begin="02:08:31.375"
        end="02:08:33.291"><span region="Default">adalah anak dari Jura…</span></p>
      <p
        begin="02:08:36.708"
        end="02:08:38.458"><span region="Default">Saya adalah anak dari Bisman.</span></p>
      <p
        begin="02:08:39.208"
        end="02:08:42.458"><span region="Default">Dan oleh karena itu,<br/>saya mewarisi harta kekayaannya.</span></p>
      <p
        begin="02:08:43.958"
        end="02:08:46.125"><span region="Default">Kekayaan yang selama ini diperoleh</span></p>
      <p
        begin="02:08:46.958"
        end="02:08:50.041"><span region="Default">dengan cara-cara<br/>yang menentang aturan agama,</span></p>
      <p
        begin="02:08:50.125"
        end="02:08:51.750"><span region="Default">melanggar aturan negara,</span></p>
      <p
        begin="02:08:52.333"
        end="02:08:54.500"><span region="Default">akan saya kembalikan sepenuhnya</span></p>
      <p
        begin="02:08:54.583"
        end="02:08:56.000"><span region="Default">kepada Bapak Ibu sekalian.</span></p>
      <p
        begin="02:08:56.916"
        end="02:08:58.208"><span region="Default">Alhamdulillah.</span></p>
      <p
        begin="02:08:58.291"
        end="02:09:00.666"><span region="Default">Piutang oleh Bisman</span></p>
      <p
        begin="02:09:01.333"
        end="02:09:03.750"><span region="Default">juga dikembalikan dan dianggap lunas.</span></p>
      <p
        begin="02:09:03.833"
        end="02:09:05.208"><span region="Default">Alhamdulillah.</span></p>
      <p
        begin="02:09:05.750"
        end="02:09:10.625"><span region="Default">Sawah-sawah yang selama ini dirampas<br/>secara paksa, dari Bapak Ibu sekalian</span></p>
      <p
        begin="02:09:10.708"
        end="02:09:13.208"><span region="Default">dikembalikan kepada Bapak Ibu seutuhnya.</span></p>
    </div>
  </body>
</tt>
